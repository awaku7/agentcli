# OpenRouter sample
UAGENT_PROVIDER=openrouter

# Required
UAGENT_OPENROUTER_API_KEY=<your-openrouter-api-key>

# Optional
UAGENT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
UAGENT_OPENROUTER_DEPNAME=openai/gpt-4o

# Optional: OpenRouter fallback extension
# UAGENT_OPENROUTER_DEPNAME=openrouter/auto
# UAGENT_OPENROUTER_FALLBACK_MODELS=anthropic/claude-4.5-sonnet,openai/gpt-4o,mistral/mistral-x

# Optional: Responses API
# UAGENT_RESPONSES=1
# UAGENT_REASONING=medium
# UAGENT_VERBOSITY=medium

# Optional: runtime
# UAGENT_WORKDIR=.
# UAGENT_LANG=ja
