# OpenAI-compatible sample
UAGENT_PROVIDER=openai

# Required
UAGENT_OPENAI_API_KEY=<your-openai-api-key>

# Optional
UAGENT_OPENAI_BASE_URL=https://api.openai.com/v1
UAGENT_OPENAI_DEPNAME=gpt-4o

# Optional: Responses API
# UAGENT_RESPONSES=1
# UAGENT_REASONING=medium    # low|medium|high|off
# UAGENT_VERBOSITY=medium    # low|medium|high|off

# Optional: runtime
# UAGENT_WORKDIR=.
# UAGENT_LANG=ja
