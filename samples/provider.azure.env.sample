# Azure OpenAI sample
UAGENT_PROVIDER=azure

# Required
UAGENT_AZURE_BASE_URL=https://<your-resource>.openai.azure.com/
UAGENT_AZURE_API_KEY=<your-azure-api-key>
UAGENT_AZURE_API_VERSION=2024-05-01-preview

# Optional
UAGENT_AZURE_DEPNAME=gpt-4o

# Optional: Responses API
# UAGENT_RESPONSES=1
# UAGENT_REASONING=medium
# UAGENT_VERBOSITY=medium

# Optional: runtime
# UAGENT_WORKDIR=.
# UAGENT_LANG=ja
