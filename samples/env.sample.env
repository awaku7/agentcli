# Cross-provider canonical env sample for uag (.env style)
#
# This file is the source of truth for generated shell variants:
#   - env.sample.sh
#   - env.sample.ps1
#   - env.sample.bat
#
# Generate them with:
#   python samples/generate_env_samples.py

# ==============================
# Provider selection
# ==============================
# azure / openai / bedrock / openrouter / gemini / grok / claude / nvidia
UAGENT_PROVIDER=openai

# ==============================
# OpenAI-compatible (UAGENT_PROVIDER=openai)
# ==============================
UAGENT_OPENAI_API_KEY=<your-openai-api-key>
# UAGENT_OPENAI_BASE_URL=https://api.openai.com/v1
# UAGENT_OPENAI_DEPNAME=gpt-4o

# ==============================
# Azure OpenAI (UAGENT_PROVIDER=azure)
# ==============================
# UAGENT_AZURE_BASE_URL=https://<your-resource>.openai.azure.com/
# UAGENT_AZURE_API_KEY=<your-azure-api-key>
# UAGENT_AZURE_API_VERSION=2024-05-01-preview
# UAGENT_AZURE_DEPNAME=gpt-4o

# ==============================
# Bedrock OpenAI-compatible gateway (UAGENT_PROVIDER=bedrock)
# ==============================
# UAGENT_BEDROCK_BASE_URL=https://<your-bedrock-gateway>/v1
# UAGENT_BEDROCK_API_KEY=<your-bedrock-api-key>
# UAGENT_BEDROCK_DEPNAME=openai.gpt-oss-120b

# ==============================
# OpenRouter (UAGENT_PROVIDER=openrouter)
# ==============================
# UAGENT_OPENROUTER_API_KEY=<your-openrouter-api-key>
# UAGENT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# UAGENT_OPENROUTER_DEPNAME=openai/gpt-4o
# Optional: OpenRouter fallback extension
# UAGENT_OPENROUTER_DEPNAME=openrouter/auto
# UAGENT_OPENROUTER_FALLBACK_MODELS=anthropic/claude-4.5-sonnet,openai/gpt-4o,mistral/mistral-x

# ==============================
# Gemini (UAGENT_PROVIDER=gemini)
# ==============================
# UAGENT_GEMINI_API_KEY=<your-gemini-api-key>
# UAGENT_GEMINI_DEPNAME=gemini-1.5-flash

# ==============================
# Grok (UAGENT_PROVIDER=grok)
# ==============================
# UAGENT_GROK_API_KEY=<your-grok-api-key>
# UAGENT_GROK_BASE_URL=https://api.x.ai/v1
# UAGENT_GROK_DEPNAME=grok-4-1-fast-reasoning

# ==============================
# Claude (UAGENT_PROVIDER=claude)
# ==============================
# UAGENT_CLAUDE_API_KEY=<your-claude-api-key>
# UAGENT_CLAUDE_DEPNAME=claude-sonnet-4.5

# ==============================
# NVIDIA (UAGENT_PROVIDER=nvidia)
# ==============================
# UAGENT_NVIDIA_API_KEY=<your-nvidia-api-key>
# UAGENT_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# UAGENT_NVIDIA_DEPNAME=nvidia/nemotron-3-nano-30b-a3b

# ==============================
# Ollama (UAGENT_PROVIDER=ollama)
# ==============================
# UAGENT_OLLAMA_BASE_URL=http://localhost:11434/v1
# UAGENT_OLLAMA_API_KEY=dummy
# UAGENT_OLLAMA_DEPNAME=llama3.1
# UAGENT_OLLAMA_TIMEOUT_SEC=60
# UAGENT_OLLAMA_TEMPERATURE=0.7
# UAGENT_OLLAMA_TOP_P=0.9
# UAGENT_OLLAMA_TOP_K=40
# UAGENT_OLLAMA_REPEAT_PENALTY=1.1
# UAGENT_OLLAMA_KEEP_ALIVE=5m
# UAGENT_OLLAMA_NUM_CTX=8192
# UAGENT_OLLAMA_NUM_PREDICT=1024

# ==============================
# Optional: Responses API (Azure/OpenAI/Bedrock)
# ==============================
# UAGENT_RESPONSES=1
# UAGENT_REASONING=medium
# UAGENT_VERBOSITY=medium

# Optional runtime
# UAGENT_WORKDIR=.
# UAGENT_LANG=ja
