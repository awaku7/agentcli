msgstr "Εγγραφές καταλόγου λίστας (π.χ. :ls / :ls .. / :ls ~ / :ls C:\\path)"

#: src/uagent/util_tools.py:2055
msgid "Manage UAGENT_* env vars and save .env.sec"
msgstr "Διαχειριστείτε το UAGENT_* env vars και αποθηκεύστε το .env.sec"

#: src/uagent/util_tools.py:2057
