#: src/uagent/runtime/runtime_env.py:186
msgid ""
"[INFO] .env.sec content does not match the current startup UAGENT_* "
"environment variables. [y] Update .env.sec with current values / [s] Use "
".env.sec values (apply to session) / [N] Skip: "
msgstr ""
"[INFO] Το περιεχόμενο του .env.sec δεν ταιριάζει με τις τρέχουσες μεταβλητές"
" περιβάλλοντος UAGENT_* κατά την εκκίνηση. [y] Ενημέρωση του .env.sec με τις"
" τρέχουσες τιμές / [s] Χρήση των τιμών του .env.sec (εφαρμογή στην περίοδο "
"λειτουργίας) / [N] Παράλειψη:"

#: src/uagent/runtime/runtime_env.py:203
msgid "[INFO] Applied .env.sec values to the current session."
msgstr ""
"[INFO] Εφαρμόστηκαν οι τιμές του .env.sec στην τρέχουσα περίοδο λειτουργίας."

#: src/uagent/runtime/runtime_env.py:212
msgid ""
"[INFO] .env.sec content does not match the current startup UAGENT_* "
"environment variables. Use `uag_envsec` to update it."
msgstr ""
"[ΠΛΗΡΟΦΟΡΙΕΣ] Το περιεχόμενο .env.sec δεν ταιριάζει με τις τρέχουσες "
"μεταβλητές περιβάλλοντος UAGENT_* εκκίνησης. Χρησιμοποιήστε το "
"\"uag_envsec\" για να το ενημερώσετε."

#: src/uagent/runtime/runtime_env.py:224
#, python-format
msgid "Updated .env.sec: %(path)s"
msgstr "Ενημερώθηκε .env.sec: %(path)s"

#: src/uagent/runtime/runtime_env.py:228
#, python-format
msgid "[WARN] Failed to update .env.sec: %(err)s"
msgstr "[ΠΡΟΕΙΔΟΠΟΙΗΣΗ] Απέτυχε η ενημέρωση του .env.sec: %(err)s"

#: src/uagent/runtime/runtime_env.py:238
msgid ""
"[INFO] .env.sec is missing. Create it from the current startup UAGENT_* "
"environment variables? [y/N] "
msgstr ""
"[ΠΛΗΡΟΦΟΡΙΕΣ] Το .env.sec λείπει. Δημιουργήστε το από τις τρέχουσες "
"μεταβλητές περιβάλλοντος UAGENT_* εκκίνησης; [ε/Δ]"

#: src/uagent/runtime/runtime_env.py:254
msgid ""
"[INFO] .env.sec is missing. Use `uag_envsec` to create it from the current "
"startup UAGENT_* environment variables."
msgstr ""
"[ΠΛΗΡΟΦΟΡΙΕΣ] Το .env.sec λείπει. Χρησιμοποιήστε το \"uag_envsec\" για να το"
" δημιουργήσετε από τις τρέχουσες μεταβλητές περιβάλλοντος UAGENT_* "
"εκκίνησης."

#: src/uagent/runtime/runtime_env.py:264
#, python-format
msgid "Created .env.sec: %(path)s"
msgstr "Δημιουργήθηκε .env.sec: %(path)s"

#: src/uagent/runtime/runtime_env.py:268
#, python-format
msgid "[WARN] Failed to create .env.sec: %(err)s"
msgstr "[ΠΡΟΕΙΔΟΠΟΙΗΣΗ] Απέτυχε η δημιουργία .env.sec: %(err)s"

#: src/uagent/runtime/runtime_env.py:299
#, python-format
msgid "[WARN] Failed to check .env.sec synchronization: %(err)s"
msgstr "[ΠΡΟΕΙΔΟΠΟΙΗΣΗ] Απέτυχε ο έλεγχος του συγχρονισμού .env.sec: %(err)s"

#: src/uagent/runtime/runtime_init.py:79
#, python-format
msgid "[WARN] Failed to decrypt .env.sec: %(err)s"
