#: src/uagent/util_tools.py:2095
msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr ""
"Μετακίνηση αρχείου ή καταλόγου (υποστηρίζει -f/--αντικατάσταση και "
"-p/--mkdirs)"

#: src/uagent/util_tools.py:2097
msgid "Show the first n lines of a file (default=20)"
msgstr "Εμφάνιση των πρώτων n γραμμών ενός αρχείου (προεπιλογή=20)"

#: src/uagent/util_tools.py:2098
msgid "Show the last n lines of a file (default=20)"
msgstr "Εμφάνιση των τελευταίων n γραμμών ενός αρχείου (προεπιλογή=20)"

#: src/uagent/util_tools.py:2100
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr "Διαγραφή αρχείων/καταλόγων με προεπισκόπηση + επιβεβαίωση"

#: src/uagent/util_tools.py:2102
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Ρυθμίστε τη λειτουργία συλλογισμού (0=απενεργοποίηση, 1=χαμηλή, 2=μέτρια, "
"3=υψηλή, αυτόματη/ελάχιστη/έξω)"

#: src/uagent/util_tools.py:2104
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
