msgstr ""
"[INFO] shrink_llm: {old_n} -> {new_n} 条消息（将 {old_part_n} 条较旧的消息压缩为 1 个总结；保留了"
" {tail_n} 条尾部消息）"

#: src/uagent/core.py:1608
