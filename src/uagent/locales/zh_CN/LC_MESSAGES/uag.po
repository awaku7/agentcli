#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:65
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- 聊天：输入消息并发送（GUI 中也可使用 Ctrl+Enter）。"

