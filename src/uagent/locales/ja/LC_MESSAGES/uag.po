msgstr "  :ls [path]            ディレクトリ一覧表示（例: :ls / :ls .. / :ls ~ / :ls C:\\path）"

#: src/uagent/core.py
msgid "  :load <idx|path>      Load a past log (overwrites current conversation history)"
msgstr "  :load <idx|path>      過去ログを読み込み（会話履歴を上書き）"

#: src/uagent/core.py
msgid "                       Note: after running, you will be asked for confirmation; choosing 'y' prepends the loaded log into the current session log file (overwrite, no backup)."
msgstr "                       ※実行後に確認が出て、y を選ぶと現在セッションのログファイル先頭へロード元ログ内容を挿入します（バックアップ無しで上書き）"

#: src/uagent/core.py
msgid "  :clean [N]            Delete conversation logs (scheck_log_*.jsonl) where the count of user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr "  :clean [N]            会話ログ（scheck_log_*.jsonl）を削除（system を除いた user/assistant/tool が N 件以下のログファイルを削除, 既定=10）"

#: src/uagent/core.py
msgid "  :shrink [N]           Shrink conversation history (keep last N non-system messages; default=40)"
msgstr "  :shrink [N]           会話履歴を単純圧縮（system 以外を末尾 N 件だけ残す, 既定=40）"

#: src/uagent/core.py
msgid "  :shrink_llm [N]       Shrink history via LLM summarization (summarize older history into 1 system message; keep last N raw; default=20)"
msgstr "  :shrink_llm [N]       LLM による要約圧縮（古い履歴を1件の要約 system にまとめ、末尾 N 件は生のまま残す, 既定=20）"

#: src/uagent/core.py
msgid "  :mem-list             List long-term memory notes"
msgstr "  :mem-list             長期記憶メモの一覧を表示"

#: src/uagent/core.py
msgid "  :mem-del <index>      Delete a long-term memory note by index (see :mem-list)"
msgstr "  :mem-del <index>      指定 index の長期記憶メモを削除（:mem-list で番号を確認）"

#: src/uagent/core.py
msgid "  :shared-mem-list      List shared long-term memory notes (requires UAGENT_SHARED_MEMORY_FILE)"
msgstr "  :shared-mem-list      共有長期記憶メモの一覧を表示（UAGENT_SHARED_MEMORY_FILE が必要）"

#: src/uagent/core.py
