#: src/uagent/core.py:1093
msgid "Available commands:"
msgstr "利用可能なコマンド:"

#: src/uagent/core.py:1094
msgid "  :help                 Show this help"
msgstr "  :help                 このヘルプを表示"

#: src/uagent/core.py:1095
msgid "  (in multiline input) \"\"\"retry  Restart input from the beginning"
msgstr "  (複数行入力中) \"\"\"retry  入力を最初からやり直す"

#: src/uagent/core.py:1096
msgid "  :logs / :list         Show log file list"
msgstr "  :logs / :list         ログファイル一覧を表示"

#: src/uagent/core.py:1098
msgid ""
"  :cd <path>            Change workdir without confirmation (e.g. :cd .. / "
":cd ~ / :cd C:\\path / :cd /)"
msgstr ""
"  :cd <path>            確認無しで作業ディレクトリ(workdir)を移動（例: :cd .. / :cd ~ / :cd "
"C:\\path / :cd /）"

#: src/uagent/core.py:1101
msgid ""
"  :ls [path]            List directory entries (e.g. :ls / :ls .. / :ls ~ / "
":ls C:\\path)"
msgstr ""
"  :ls [path]            ディレクトリ一覧表示（例: :ls / :ls .. / :ls ~ / :ls C:\\path）"

#: src/uagent/core.py:1104
msgid ""
"  :load <idx|path>      Load a past log (overwrites current conversation "
"history)"
msgstr "  :load <idx|path>      過去ログを読み込み（会話履歴を上書き）"

#: src/uagent/core.py:1107
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       ※実行後に確認が出て、y "
"を選ぶと現在セッションのログファイル先頭へロード元ログ内容を挿入します（バックアップ無しで上書き）"

#: src/uagent/core.py:1110
msgid ""
"  :clean [N]            Delete conversation logs (scheck_log_*.jsonl) where "
"the count of user/assistant/tool messages (excluding system) is <= N "
"(default=10)"
msgstr ""
"  :clean [N]            会話ログ（scheck_log_*.jsonl）を削除（system を除いた "
"user/assistant/tool が N 件以下のログファイルを削除, 既定=10）"

#: src/uagent/core.py:1113
msgid ""
"  :shrink [N]           Shrink conversation history (keep last N non-system "
"messages; default=40)"
msgstr "  :shrink [N]           会話履歴を単純圧縮（system 以外を末尾 N 件だけ残す, 既定=40）"

#: src/uagent/core.py:1116
msgid ""
"  :shrink_llm [N]       Shrink history via LLM summarization (summarize "
"older history into 1 system message; keep last N raw; default=20)"
msgstr ""
"  :shrink_llm [N]       LLM による要約圧縮（古い履歴を1件の要約 system にまとめ、末尾 N 件は生のまま残す, "
"既定=20）"

#: src/uagent/core.py:1118
msgid "  :mem-list             List long-term memory notes"
msgstr "  :mem-list             長期記憶メモの一覧を表示"

#: src/uagent/core.py:1120
msgid ""
"  :mem-del <index>      Delete a long-term memory note by index (see :mem-"
"list)"
msgstr "  :mem-del <index>      指定 index の長期記憶メモを削除（:mem-list で番号を確認）"

#: src/uagent/core.py:1123
msgid ""
"  :shared-mem-list      List shared long-term memory notes (requires "
"UAGENT_SHARED_MEMORY_FILE)"
msgstr "  :shared-mem-list      共有長期記憶メモの一覧を表示（UAGENT_SHARED_MEMORY_FILE が必要）"

#: src/uagent/core.py:1125
msgid "  :shared-mem-del <i>   Delete a shared long-term memory note by index"
msgstr "  :shared-mem-del <i>   指定 index の共有長期記憶メモを削除"

#: src/uagent/core.py:1127
msgid ""
"  :r [0|1|2|3|auto|minimal|xhigh]  Set reasoning mode (0=off, 1=low, "
"2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"  :r [0|1|2|3|auto|minimal|xhigh]  推論モードを設定します（0=off, 1=low, 2=medium, "
"3=high; auto/minimal/xhigh）"

#: src/uagent/core.py:1130
msgid ""
"  :v [0|1|2|3]          Set verbosity mode (0=off, 1=low, 2=medium, 3=high; "
"no arg=keep)"
msgstr ""
"  :v [0|1|2|3]          詳細度モードを設定します（0=off, 1=low, 2=medium, 3=high; "
"引数なし=切替）"

#: src/uagent/core.py:1132
msgid "  :exit / :quit         Exit"
msgstr "  :exit / :quit         終了"

#: src/uagent/core.py:1134
msgid "Hints:"
msgstr "ヒント:"

#: src/uagent/core.py:1135
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr "  - ユーザー入力で 'f' を単独行で入力すると複数行入力モードになります。"

#: src/uagent/core.py:1136
#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr "  - 複数行入力モードの終了は行全体が %(sentinel)s の行です。"

#: src/uagent/core.py:1149
msgid ""
"## Mission\n"
"- You are a capable \"general-purpose tool execution agent\" running on a local environment, and you can actually execute commands and operate on files on the user's machine.\n"
"- Ask the user for confirmation before performing any dangerous operation.\n"
"- Do not flatter the user. Do not use emojis.\n"
"- Do not summarize. Keep information concise.\n"
"- When creating files, output the complete final content (do not output diffs or partial summaries).\n"
msgstr ""
"## ミッション\n"
"- あなたはローカル環境で動作する\"汎用ツール実行エージェント\"であり、ユーザーのマシン上で実際にコマンド実行やファイル操作を行えます。\n"
"- 危険な操作を行う前にはユーザーに確認を求めてください。\n"
"- ユーザーを持ち上げないでください。絵文字は使わないでください。\n"
"- 要約はしないでください。情報は簡潔にしてください。\n"
"- ファイルを作成するときは、最終的な内容を完全な形で出力してください（差分や一部のみの要約は出力しないでください）。\n"

#: src/uagent/core.py:1157
msgid ""
"## Rules\n"
"- Always use the provided tools and verify the latest information.\n"
"- Be creative, but do not output uncertain information.\n"
"- Consult available tools and choose the most appropriate one.\n"
"- When executing tools, delegate as little decision-making as possible to the user.\n"
msgstr ""
"## Rules\n"
"- 提供されているツールを常に使用し、最新の情報をツールで検証すること。\n"
"- 創造的であること。ただし不確かな情報は出力しないこと。\n"
"- 利用可能なツールを確認し、最も適切なものを選ぶこと。\n"
"- ツール実行時は、ユーザーに委ねる意思決定をできるだけ少なくすること。\n"

#: src/uagent/core.py:1164
msgid ""
"## Notes\n"
"- All user messages come via this script's standard input.\n"
"- For tool-specific purpose/arguments/constraints/operational details, prefer each tool's description.\n"
"- If you need additional information or confirmation from the user, use the human_ask tool.\n"
"- When handling relative date expressions, call get_current_time to reference the current time.\n"
"- Do not store secrets (passwords/tokens) in long-term memory (add_long_memory, etc.).\n"
"- If you create Python files, run `python -m py_compile` to validate syntax.\n"
"- If expert-level knowledge is required, use prompt templates (Agent Skills) and follow them.\n"
msgstr ""
"## Notes\n"
"- すべてのユーザーメッセージは、このスクリプトの標準入力から渡されます。\n"
"- ツール固有の目的/引数/制約/運用上の詳細は、各ツールの説明を優先してください。\n"
"- 追加情報や確認が必要な場合は human_ask ツールを使用してください。\n"
"- 相対日付表現を扱う場合は、現在時刻参照のため get_current_time を呼び出してください。\n"
"- 秘密情報（パスワード/トークン等）を長期記憶（add_long_memory 等）に保存しないでください。\n"
"- Python ファイルを作成した場合は、構文検証のため `python -m py_compile` を実行してください。\n"
"- 専門的な知識が必要な場合は、プロンプトテンプレート（Agent Skills）を使用し、それに従ってください。\n"

#: src/uagent/core.py:1174
msgid ""
"## Dangerous operation policy (delete_file)\n"
"- For deletion using the delete_file tool, do NOT ask for confirmation before preview.\n"
"- Always run delete_file with dry_run=true first to get the list of deletion candidates.\n"
"- Show the candidates to the user and ask confirmation via human_ask exactly once.\n"
"- Only when the user explicitly replies \"y\" or \"yes\" (or equivalent explicit approval), run delete_file again with the same parameters and dry_run=false.\n"
"- If there are zero candidates, do not ask; just report that nothing will be deleted.\n"
msgstr ""
"## 危険な操作ポリシー（delete_file）\n"
"- delete_file ツールで削除する場合、プレビュー前に確認を求めないでください。\n"
"- まず dry_run=true で delete_file を実行し、削除候補の一覧を取得してください。\n"
"- 候補をユーザーに提示し、human_ask による確認は 1 回だけ求めてください。\n"
"- ユーザーが \"y\" または \"yes\"（または同等の明確な承認）と明示的に返信した場合にのみ、同じパラメータで dry_run=false を指定して delete_file を再実行してください。\n"
"- 候補が 0 件の場合は確認を求めず、何も削除されないことを報告してください。\n"

#: src/uagent/core.py:1182
msgid ""
"## Mission\n"
"- You are a capable \"general-purpose tool execution agent\" running on a local environment; you can execute commands and operate on the user's machine.\n"
"- Ask the user for confirmation before any dangerous operation.\n"
"- No flattery. No emojis. No conversation summaries. Keep it concise.\n"
"- When creating files, output the complete final content (no diffs/partial summaries).\n"
msgstr ""
"## ミッション\n"
"- あなたはローカル環境で動作する\"汎用ツール実行エージェント\"です。ユーザーのマシン上でコマンド実行やファイル操作を行えます。\n"
"- 危険な操作を行う前にはユーザーに確認を求めてください。\n"
"- 持ち上げる表現はしないでください。絵文字は使わないでください。会話の要約もしないでください。簡潔にしてください。\n"
"- ファイルを作成するときは、最終的な内容を完全な形で出力してください（差分や一部のみの要約は出力しないでください）。\n"

#: src/uagent/core.py:1189
msgid ""
"## Rules\n"
"- Use the provided tools first and verify results with tools.\n"
"- Consult tool descriptions for purpose/arguments/constraints; choose the most appropriate and safest tool.\n"
"- Be creative, but do not output uncertain information.\n"
"- Delegate as little decision-making as possible to the user.\n"
msgstr ""
"## Rules\n"
"- 提供されているツールを優先して使用し、結果はツールで検証してください。\n"
"- ツール説明の目的/引数/制約を確認し、最も適切かつ安全なツールを選んでください。\n"
"- 創造的であること。ただし不確かな情報は出力しないこと。\n"
"- ユーザーに委ねる意思決定をできるだけ少なくしてください。\n"

#: src/uagent/core.py:1196
msgid ""
"## Notes\n"
"- All user messages come via this script's standard input.\n"
"- If required info/parameters are missing, ask via human_ask (do not guess).\n"
"- Relative dates: call get_current_time.\n"
"- Do not store secrets (passwords/tokens) in long-term memory.\n"
"- If you create Python files, run `python -m py_compile`.\n"
"- If expert-level knowledge is required, use Agent Skills prompt templates.\n"
msgstr ""
"## Notes\n"
"- すべてのユーザーメッセージは、このスクリプトの標準入力から渡されます。\n"
"- 必要な情報/パラメータが不足している場合は、human_ask で質問してください（推測しない）。\n"
