#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[Hızlı Kılavuz]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- Sohbet: bir mesaj yazın ve gönderin (GUI: Ctrl+Enter da mevcuttur)."

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Çok satırlı: çok satırlı moda girmek için yalnızca 'f' olan bir satır "
"girin (\"\"\" sonu ile bitirin)."

#: src/uagent/welcome.py:68
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.)."
msgstr ""
"- Komutlar: Sistem komutlarını (günlük yönetimi, geçmiş sıkıştırma vb.) "
"görmek için ':help' yazın."

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Çıkış: ':exit' veya ':quit' oturumu sonlandırır."

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Resimler: GUI sürükle ve bırak özelliğini destekler; CUI'de görüntü "
"analizi için bir dosya yolu girebilirsiniz."

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs: `%(docs_cmd)s` birlikte verilen belgeleri gösterir; "
"`%(webinspect_cmd)s` Web Inspector yardımını gösterir (`--path/--open` de "
"kullanılabilir)."

#: src/uagent/welcome.py:79
msgid "[Examples]"
msgstr "[Örnekler]"

#: src/uagent/welcome.py:80
msgid "- \"Analyze the source code in this folder and create a README.md.\""
msgstr "- \"Bu klasördeki kaynak kodunu analiz edin ve bir README.md oluşturun.\""

#: src/uagent/welcome.py:82
msgid ""
"- \"Take a screenshot of the current desktop and describe the visible window"
" contents.\""
msgstr ""
"- \"Geçerli masaüstünün ekran görüntüsünü alın ve görünen pencere içeriğini "
"tanımlayın.\""

#: src/uagent/welcome.py:84
msgid "- \"Create a monthly summary report from this Excel file.\""
msgstr "- \"Bu Excel dosyasından aylık bir özet rapor oluşturun.\""

#: src/uagent/welcome.py:85
msgid "- \"Read this PDF and list three key points.\""
msgstr "- \"Bu PDF'yi okuyun ve üç önemli noktayı listeleyin.\""

#: src/uagent/welcome.py:86
msgid "- \"Search the latest news and summarize a specific topic.\""
msgstr "- \"En son haberleri arayın ve belirli bir konuyu özetleyin.\""

