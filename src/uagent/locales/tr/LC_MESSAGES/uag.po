msgstr "Dosya veya dizin taşı (-f/--overwrite ve -p/--mkdirs desteklenir)"

#: src/uagent/util_tools.py:1828
msgid "Show the first n lines of a file (default=20)"
msgstr "Bir dosyanın ilk n satırını göster (varsayılan=20)"

#: src/uagent/util_tools.py:1830
msgid "Show the last n lines of a file (default=20)"
msgstr "Bir dosyanın son n satırını göster (varsayılan=20)"

#: src/uagent/util_tools.py:1832
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr "Önizleme + onaylama ile dosya(lar)ı/dizin(ler)i sil"

#: src/uagent/util_tools.py:1834
msgid ""
"List shared long-term memory notes (requires UAGENT_SHARED_MEMORY_FILE)"
msgstr ""
"Paylaşılan uzun süreli hafıza notlarını listeleyin "
"(UAGENT_SHARED_MEMORY_FILE gerektirir)"

#: src/uagent/util_tools.py:1836
msgid "Delete a shared long-term memory note by index"
msgstr "Paylaşılan uzun süreli hafıza notunu dizine göre silme"

#: src/uagent/util_tools.py:1838
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Akıl yürütme modunu ayarlayın (0=kapalı, 1=düşük, 2=orta, 3=yüksek; "
"otomatik/minimum/xyüksek)"

#: src/uagent/util_tools.py:1840
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Ayrıntı modunu ayarlayın (0=kapalı, 1=düşük, 2=orta, 3=yüksek; bağımsız "
"değişken yok=tut)"

#: src/uagent/util_tools.py:1841
msgid "Exit"
msgstr "Çıkış"

#: src/uagent/util_tools.py:1844
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr ""
"- Çok satırlı giriş moduna girmek için yalnızca 'f' olan bir satır girin."

#: src/uagent/util_tools.py:1846
#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"- Çok satırlı giriş modunu sonlandırmak için tam olarak %(sentinel)s olan "
"bir satır girin."

#: src/uagent/util_tools.py:1952
msgid "Exiting."
msgstr "Çıkıyorum."

#: src/uagent/util_tools.py:1955
#, python-format
msgid "Unknown command: :%(cmd)s"
msgstr "Bilinmeyen komut: :%(cmd)s"

#: src/uagent/util_tools.py:2106
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"Aşağıda listelenen maddeler bu kullanıcının uzun süreli hafızasından (kalıcı"
" notlar) alıntılardır. Bunları kullanıcı hakkında arka plan bilgisi olarak "
"kullanın. Ancak, konuşmada her zaman yeni sağlanan bilgilere öncelik verin "
"ve eski bilgilerle çelişiyorsa en son bilgileri benimseyin."

#: src/uagent/web.py:511
msgid ""
"Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"Bu odada başka bir görev zaten çalışıyor. Lütfen tamamlandıktan sonra tekrar"
" deneyin."

#: src/uagent/web.py:604 src/uagent/web.py:723
msgid ""
"Environment variable UAGENT_PROVIDER is not set.\n"
"Please check environment variables when starting the web server."
msgstr ""
"UAGENT_PROVIDER ortam değişkeni ayarlanmamış.\n"
"Lütfen web sunucusunu başlatırken ortam değişkenlerini kontrol edin."

