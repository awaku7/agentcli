#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1504
msgid "Available commands:"
msgstr "可用命令："

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1505
msgid "  :help                 Show this help"
msgstr "  :help                 顯示此幫助"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1506
msgid "  (in multiline input) \"\"\"retry  Restart input from the beginning"
msgstr "  （多行輸入中）\"\"\"retry  从头重新開始輸入"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1507
msgid "  :logs / :list         Show log file list"
msgstr "  :logs / :list         顯示日志檔案列表"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1509
msgid ""
"  :cd <path>            Change workdir without confirmation (e.g. :cd .. / "
":cd ~ / :cd C:\\path / :cd /)"
msgstr ""
"  :cd <path>            无需確認即可更改工作目錄（例如：:cd .. / :cd ~ / :cd C:\\path / :cd "
"/）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1512
msgid ""
"  :ls [path]            List directory entries (e.g. :ls / :ls .. / :ls ~ / "
":ls C:\\path)"
msgstr "  :ls [path]            列出目錄条目（例如：:ls / :ls .. / :ls ~ / :ls C:\\path）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1514
msgid "  :tools                List loaded tools"
msgstr "  :tools                列出已載入的工具"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1516
msgid ""
"  :skills [cmd]         Manage/apply skills (e.g. :skills / :skills active /"
" :skills clear)"
msgstr ""
"  :skills [cmd]         管理/套用 skill（例如：:skills / :skills active / :skills "
"clear）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1519
msgid ""
"  :load <idx|path>      Load a past log (overwrites current conversation "
"history)"
msgstr "  :load <idx|path>      載入过去的日志（会覆盖当前會話歷史）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1522
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       注意：运行后会要求確認；選擇 'y' 会把載入的日志追加到当前會話日志檔案开头（覆盖写入，不备份）。"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1525
msgid ""
"  :clean [N]            Delete conversation logs (scheck_log_*.jsonl) where "
"the count of user/assistant/tool messages (excluding system) is <= N "
"(default=10)"
msgstr ""
"  :clean [N]            刪除对话日志（scheck_log_*.jsonl），其中用户/助手/工具訊息數（不含系統）<= "
"N（預設=10）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1528
msgid ""
"  :shrink [N]           Shrink conversation history (keep last N non-system "
"messages; default=40)"
msgstr "  :shrink [N]           收缩會話歷史（保留最近 N 条非系統訊息；預設=40）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1531
msgid ""
"  :shrink_llm [N]       Shrink history via LLM summarization (summarize "
"older history into 1 system message; keep last N raw; default=20)"
msgstr ""
"  :shrink_llm [N]       透過 LLM 摘要收缩歷史（将较早歷史总结为 1 条系統訊息；保留最近 N 条原文；預設=20）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1533
msgid "  :mem-list             List long-term memory notes"
msgstr "  :mem-list             列出長期記憶笔记"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1535
msgid ""
"  :mem-del <index>      Delete a long-term memory note by index (see :mem-"
"list)"
msgstr "  :mem-del <index>      按索引刪除長期記憶笔记（参见 :mem-list）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1538
msgid ""
"  :rm <path|glob>       Delete file(s)/directory(ies) with preview + confirm"
msgstr "  :rm <path|glob>       透過预览和確認刪除檔案/目錄"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1541
msgid ""
"  :shared-mem-list      List shared long-term memory notes (requires "
"UAGENT_SHARED_MEMORY_FILE)"
msgstr "  :shared-mem-list      列出共享長期記憶笔记（需要 UAGENT_SHARED_MEMORY_FILE）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1543
msgid "  :shared-mem-del <i>   Delete a shared long-term memory note by index"
msgstr "  :shared-mem-del <i>   按索引刪除共享長期記憶笔记"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1545
msgid ""
"  :r [0|1|2|3|auto|minimal|xhigh]  Set reasoning mode (0=off, 1=low, "
"2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"  :r [0|1|2|3|auto|minimal|xhigh]  "
"設定推理模式（0=关闭，1=低，2=中，3=高；auto/minimal/xhigh）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1548
msgid ""
"  :v [0|1|2|3]          Set verbosity mode (0=off, 1=low, 2=medium, 3=high; "
"no arg=keep)"
msgstr "  :v [0|1|2|3]          設定詳細程度（0=关闭，1=低，2=中，3=高；无参數=保持）"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1550
msgid "  :exit / :quit         Exit"
msgstr "  :exit / :quit         退出"

