msgstr ""
"[INFO] shrink_llm: {old_n} -> {new_n} 條訊息（將 {old_part_n} 條較舊的訊息壓縮為 1 個總結；保留了"
" {tail_n} 條尾部訊息）"

#: src/uagent/core.py:1460
msgid ""
