"[MCP Servers]\n"
"- Config file not found."
msgstr ""
"[MCP 伺服器]\n"
"- 找不到設定檔。"

#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:34
msgid ""
"[MCP Servers]\n"
"- No servers registered."
msgstr ""
"[MCP 伺服器]\n"
"- 未註冊任何伺服器。"

