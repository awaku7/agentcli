#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:64
msgid "[Quick Guide]"
msgstr "[Guide rapide]"

#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:65
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr ""
"- Chat : saisissez un message et envoyez-le (interface graphique : "
"Ctrl+Entrée est aussi disponible)."

#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:67
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Saisie multiligne : saisissez une ligne composée uniquement de 'f' pour "
"entrer en mode multiligne (terminez avec \"\"\"end)."

#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:70
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.). Note: commands start with ':' (colon) instead of '/' "
"(slash)."
msgstr ""
"- Commandes : tapez ':help' pour voir les commandes système (gestion des "
"journaux, compression de l'historique, etc.). Remarque : les commandes "
"commencent par ':' (deux-points) au lieu de '/' (barre oblique)."

#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:72
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Quitter : ':exit' ou ':quit' termine la session."

#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:74
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Images : l’interface graphique prend en charge le glisser-déposer ; en "
"interface texte, vous pouvez fournir un chemin de fichier pour l’analyse "
"d’image."

#: C:\KAIHATSU\agentcli\src\uagent\welcome.py:77
#, python-format
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs : `%(docs_cmd)s` affiche les documents inclus ; `%(webinspect_cmd)s` "
"affiche l’aide de Web Inspector (`--path/--open` également disponibles)."

