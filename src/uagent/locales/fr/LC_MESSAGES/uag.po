msgstr "La variable d'environnement %(name)s n'est pas définie."

#: src/uagent/core.py:533
msgid "No log files found."
msgstr "Aucun fichier de journal trouvé."

#: src/uagent/core.py:554
#, python-format
msgid "logs: showing %(shown)d/%(total)d (dir=%(dir)s)"
msgstr "logs : affichage de %(shown)d/%(total)d (dir=%(dir)s)"

#: src/uagent/core.py:557
msgid "Log files:"
msgstr "Fichiers de journal :"

#: src/uagent/core.py:957
msgid ""
"- Summarize the conversation log so far in English.\n"
"- Keep the summary concise but include key decisions, constraints, and pending items.\n"
"- Output should be directly usable as a system message titled 'Summary of the conversation so far'.\n"
msgstr ""
"- Résumez le journal de conversation jusqu'à présent en anglais.\n"
"- Gardez le résumé concis, mais incluez les décisions clés, les contraintes et les éléments en attente.\n"
"- La sortie doit être directement utilisable comme message système intitulé 'Summary of the conversation so far'.\n"

#: src/uagent/core.py:991
#, python-format
msgid "Error while calling LLM for history compression: %(err)r"
msgstr ""
"Erreur lors de l'appel du LLM pour la compression de l'historique : %(err)r"

#: src/uagent/core.py:1009
msgid "Summary of the conversation so far:\n"
msgstr "Résumé de la conversation jusqu’à présent :\n"

#: src/uagent/core.py:1017
#, python-brace-format
msgid ""
"[INFO] Conversation history was summarized by the LLM: old_part={old_n} -> 1"
" summary + tail_part={tail_n}"
msgstr ""
"[INFO] L'historique de la conversation a été résumé par le LLM : "
"old_part={old_n} -> 1 summary + tail_part={tail_n}"

#: src/uagent/core.py:1032
msgid "Available commands:"
msgstr "Available commandes:"

#: src/uagent/core.py:1033
msgid "  :help                 Show this help"
msgstr "  :help                 Afficher cette aide"

#: src/uagent/core.py:1034
msgid "  (in multiline input) \"\"\"retry  Restart input from the beginning"
msgstr "  (en saisie multiligne) \"\"\"retry  Recommencer la saisie depuis le début"

#: src/uagent/core.py:1035
msgid "  :logs / :list         Show log file list"
msgstr "  :logs / :list         Afficher la liste des fichiers de journal"

#: src/uagent/core.py:1037
msgid ""
"  :cd <path>            Change workdir without confirmation (e.g. :cd .. / "
":cd ~ / :cd C:\\path / :cd /)"
msgstr ""
"  :cd <path>            Change répertoire de travail without confirmation "
"(e.g. :cd .. / :cd ~ / :cd C:\\path / :cd /)"

#: src/uagent/core.py:1040
msgid ""
"  :ls [path]            List directory entries (e.g. :ls / :ls .. / :ls ~ / "
":ls C:\\path)"
msgstr ""
"  :ls [path]            Lister les entrées du répertoire (ex. : :ls / :ls .."
" / :ls ~ / :ls C:\\path)"

#: src/uagent/core.py:1043
msgid ""
"  :load <idx|path>      Load a past log (overwrites current conversation "
"history)"
msgstr ""
"  :load <idx|path>      Charger un journal précédent (écrase l'historique "
"actuel)"

#: src/uagent/core.py:1046
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Remarque : après exécution, une confirmation vous "
"sera demandée ; si vous choisissez 'y', le journal chargé sera préfixé au "
"fichier de journal de la session en cours (écrasement, sans sauvegarde)."

#: src/uagent/core.py:1049
msgid ""
"  :clean [N]            Delete conversation logs (scheck_log_*.jsonl) where "
"the count of user/assistant/tool messages (excluding system) is <= N "
"(default=10)"
msgstr ""
"  :clean [N]            Supprimer les journaux de conversation "
"(scheck_log_*.jsonl) dont le nombre de messages utilisateur/assistant/outils"
" (hors system) est <= N (par défaut=10)"

#: src/uagent/core.py:1052
msgid ""
"  :shrink [N]           Shrink conversation history (keep last N non-system "
"messages; default=40)"
msgstr ""
"  :shrink [N]           Réduire l'historique (conserver les N derniers "
"messages hors system ; par défaut=40)"

#: src/uagent/core.py:1055
msgid ""
"  :shrink_llm [N]       Shrink history via LLM summarization (summarize "
"older history into 1 system message; keep last N raw; default=20)"
msgstr ""
"  :shrink_llm [N]       Réduire l'historique via résumé par le LLM (résumer "
"l'ancien historique en 1 message system ; conserver les N derniers bruts ; "
"par défaut=20)"

#: src/uagent/core.py:1057
msgid "  :mem-list             List long-term memory notes"
msgstr "  :mem-list             Lister les notes de mémoire à long terme"

#: src/uagent/core.py:1059
msgid ""
"  :mem-del <index>      Delete a long-term memory note by index (see :mem-"
"list)"
msgstr ""
"  :mem-del <index>      Supprimer une note de mémoire à long terme par index"
" (voir :mem-list)"

#: src/uagent/core.py:1062
msgid ""
"  :shared-mem-list      List shared long-term memory notes (requires "
"UAGENT_SHARED_MEMORY_FILE)"
msgstr ""
"  :shared-mem-list      Lister les notes de mémoire partagée à long terme "
"(nécessite UAGENT_SHARED_MEMORY_FILE)"

#: src/uagent/core.py:1064
msgid "  :shared-mem-del <i>   Delete a shared long-term memory note by index"
msgstr ""
"  :shared-mem-del <i>   Supprimer une note de mémoire partagée par index"

#: src/uagent/core.py:1066
msgid ""
"  :r [0|1|2|3|auto|minimal|xhigh]  Set reasoning mode (0=off, 1=low, "
"2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"  :r [0|1|2|3|auto|minimal|xhigh]  Définir le mode de raisonnement (0=off, "
"1=low, 2=medium, 3=high ; auto/minimal/xhigh)"

#: src/uagent/core.py:1069
msgid ""
"  :v [0|1|2|3]          Set verbosity mode (0=off, 1=low, 2=medium, 3=high; "
"no arg=cycle)"
msgstr ""
"  :v [0|1|2|3]          Définir le mode de verbosité (0=off, 1=low, "
"2=medium, 3=high ; sans argument=cycle)"

#: src/uagent/core.py:1071
msgid "  :exit / :quit         Exit"
msgstr "  :exit / :quit         Quitter"

#: src/uagent/core.py:1073
msgid "Hints:"
msgstr "Astuces :"

#: src/uagent/core.py:1074
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr ""
"  - Entrez une ligne contenant uniquement 'f' pour passer en mode de saisie "
"multiligne."

#: src/uagent/core.py:1075
#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"  - Pour terminer le mode multiligne, entrez une ligne qui soit exactement "
"%(sentinel)s."

