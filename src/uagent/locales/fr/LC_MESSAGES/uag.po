msgstr ""
"[WARN] Le LLM a renvoyé un message d'assistant vide sans appel d'outil.\n"
"provider=%(provider)s depname=%(depname)s empty_no_tool_rounds=%(empty_no_tool_rounds)s (max=%(empty_no_tool_max)s)\n"
