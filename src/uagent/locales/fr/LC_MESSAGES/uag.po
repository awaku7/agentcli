#: src/uagent/util_tools.py:1391
#, python-format
msgid ""
"will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Supprimera les fichiers journaux de conversation (scheck_log_*.jsonl) du disque.\n"
"Dossier des journaux : %(dir)s\n"
"Règle : le nombre total de messages user/assistant/tool hors system doit être <= %(threshold)d\n"
"Cibles : %(n)d\n"
"\n"
"Continuer ? Entrez y pour exécuter, ou c pour annuler."

