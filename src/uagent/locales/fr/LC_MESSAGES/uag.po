#: src/uagent/util_tools.py:1351
#, python-format
msgid ""
"[shrink_llm error] Failed to parse as int: %(arg)r -> keep last %(keep)d"
msgstr ""
"[erreur shrink_llm] Impossible d’analyser la valeur en entier : %(arg)r -> "
"conserver les %(keep)d derniers"

#: src/uagent/util_tools.py:1413 src/uagent/util_tools.py:1446
msgid ""
"Shared long-term memory is not enabled (UAGENT_SHARED_MEMORY_FILE is not "
"set)."
msgstr ""
"La mémoire longue durée partagée n’est pas activée "
"(UAGENT_SHARED_MEMORY_FILE n’est pas défini)."

#: src/uagent/util_tools.py:1793
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"Les points ci-dessous sont des extraits de la mémoire à long terme de cet utilisateur (mémos persistants). Utilisez-les comme contexte sur l'utilisateur. Toutefois, accordez toujours la priorité aux informations nouvellement fournies dans la conversation, et si elles contredisent des informations plus anciennes, adoptez les plus récentes.\n"
"\n"

#: src/uagent/web.py:504
msgid ""
"Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"Une autre tâche est déjà en cours dans cette salle. Réessayez une fois "
"qu'elle sera terminée."

#: src/uagent/web.py:592 src/uagent/web.py:761
msgid ""
"Environment variable UAGENT_PROVIDER is not set.\n"
