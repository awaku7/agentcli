#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1523
msgid "Load a past log (overwrites current conversation history)"
msgstr ""
"Charger un journal précédent (écrase l'historique de conversation actuel)"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1525
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Remarque : après exécution, une confirmation vous "
"sera demandée ; en choisissant 'y', le journal chargé sera ajouté au début "
"du fichier journal de la session en cours (écrasement, sans sauvegarde)."

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1529
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"Supprimer les journaux de conversation (scheck_log_*.jsonl) dont le nombre "
"de messages user/assistant/tool hors system est <= N (par défaut=10)"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1533
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"Réduire l'historique de conversation (conserver les N derniers messages non-"
"system ; par défaut=40)"

#: F:\KAIHATSU\agentcli\src\uagent\util_tools.py:1537
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"Réduire l'historique via résumé LLM (résumer l'historique ancien en 1 "
"message system ; conserver les N derniers bruts ; par défaut=20)"

