#: src/uagent/util_tools.py:201
msgid ""
"Non-interactive mode. Do not start the stdin loop; exit after processing the"
" startup file (if any)."
msgstr ""
"Mode non interactif. Ne démarrez pas la boucle stdin ; quittez après le "
"traitement du fichier de démarrage (s'il y en a un)."

#: src/uagent/util_tools.py:650
msgid ""
"[Skill execution]\n"
"This skill is intended to be run. Read the skill body carefully and follow the instructions.\n"
"If the skill contains tasks, continue until they are complete.\n"
"Use tools as needed.\n"
msgstr ""
"[Exécution de la compétence]\n"
"Cette compétence est destinée à être exécutée. Lisez attentivement le corps de la compétence et suivez les instructions.\n"
"Si la compétence contient des tâches, continuez jusqu'à leur achèvement.\n"
"Utilisez les outils si nécessaire.\n"

#: src/uagent/util_tools.py:657
msgid "When finished, always call `finish_skill` if available.\n"
msgstr "Une fois terminé, appelez toujours `finish_skill` si disponible.\n"

#: src/uagent/util_tools.py:793
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"Sélectionnez un numéro de compétence à exécuter. Entrez c pour annuler.\n"
"Astuce : :skills clear  (supprimer les compétences appliquées)\n"
"Entrez un numéro :"

#: src/uagent/util_tools.py:829
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Exécutez cette compétence comme instruction système et gardez-la active dans cette session ?\n"
"\n"
"Nom : %(name)s\n"
"Chemin : %(path)s\n"
"\n"
"Continuer ? Entrez y pour exécuter, ou c pour annuler."

#: src/uagent/util_tools.py:937
#, python-format
msgid ""
":clean will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
":clean supprimera les fichiers journaux de conversation (scheck_log_*.jsonl) du disque.\n"
"Répertoire des journaux : %(dir)s\n"
"Règle : le total des messages utilisateur/assistant/outils, hors système, doit être inférieur ou égal à %(threshold)d\n"
"Cibles : %(n)d\n"
"\n"
"Continuer ? Entrez y pour exécuter, ou c pour annuler."

#: src/uagent/util_tools.py:1181
#, python-brace-format
msgid ""
"Delete {count} path(s)?\n"
"\n"
"{paths}\n"
"\n"
"Enter y to proceed, or c to cancel."
msgstr ""
"Supprimer {count} chemin(s) ?\n"
"\n"
"{paths}\n"
"\n"
"Entrez y pour continuer, ou c pour annuler."

#: src/uagent/util_tools.py:1322
#, python-format
