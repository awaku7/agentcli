msgstr ""
"[WARN] طول زمینهٔ فشرده‌سازی تاریخچه از حد گذشت؛ تلاش دوباره با "
"chunk_size=%(chunk_size)d"

#: src/uagent/core.py:1488
msgid ""
"[WARN] history compression failed due to LLM error; falling back to "
"shrink_messages()."
msgstr ""
"[WARN] فشرده‌سازی تاریخچه به دلیل خطای LLM شکست خورد؛ بازگشت به "
"shrink_messages()."

