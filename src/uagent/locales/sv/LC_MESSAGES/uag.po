msgstr "- Avsluta: ':exit' eller ':quit' avslutar sessionen."

#: F:\KAIHATSU\agentcli\src\uagent\welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Bilder: GUI stöder dra & släpp; i CUI kan du ange en filsökväg för "
"bildanalys."

