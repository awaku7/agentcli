#: src/uagent/core.py:1379
msgid "- Summarize the conversation chunk in English.\n"
msgstr "- Sammanfatta konversationssegmentet på engelska.\n"

#: src/uagent/core.py:1381
msgid ""
"- Keep the summary concise but include key decisions, constraints, and "
"pending items.\n"
msgstr ""
"- Håll sammanfattningen kortfattad men inkludera viktiga beslut, "
"begränsningar och utestående punkter.\n"

#: src/uagent/core.py:1383
msgid "- Output should be directly usable as a system message."
msgstr "- Utdata ska kunna användas direkt som ett systemmeddelande."

#: src/uagent/core.py:1386
msgid "Conversation chunk:\n"
msgstr "Konversationssegment:\n"

#: src/uagent/core.py:1388
msgid "Write a concise summary of this chunk."
msgstr "Skriv en kortfattad sammanfattning av detta segment."

#: src/uagent/core.py:1392
msgid "- You are updating an existing conversation summary.\n"
msgstr "- Du uppdaterar en befintlig konversationssammanfattning.\n"

#: src/uagent/core.py:1393
msgid "- Preserve important facts from the previous summary.\n"
msgstr "- Bevara viktiga fakta från den tidigare sammanfattningen.\n"

#: src/uagent/core.py:1395
msgid ""
"- Merge in the new chunk without losing constraints, decisions, or pending "
"items.\n"
msgstr ""
"- Slå samman det nya segmentet utan att förlora begränsningar, beslut eller "
"utestående punkter.\n"

#: src/uagent/core.py:1397
msgid "- Keep the result concise and suitable for a system message."
msgstr "- Håll resultatet kortfattat och lämpligt för ett systemmeddelande."

#: src/uagent/core.py:1400
msgid "Previous summary:\n"
msgstr "Tidigare sammanfattning:\n"

#: src/uagent/core.py:1402
msgid "New chunk:\n"
msgstr "Nytt segment:\n"

#: src/uagent/core.py:1404
msgid "Update the summary while keeping the prior context intact."
msgstr "Uppdatera sammanfattningen med bibehållen tidigare kontext."

#: src/uagent/core.py:1425
msgid "Summary of the conversation so far:\n"
msgstr "Sammanfattning av konversationen hittills:\n"

#: src/uagent/core.py:1432
msgid ""
"[INFO] shrink_llm: {old_n} -> {new_n} messages (compressed {old_part_n} "
"older messages into 1 summary; kept {tail_n} tail)"
msgstr ""
"[INFO] shrink_llm: {old_n} -> {new_n} meddelanden ({old_part_n} äldre "
"meddelanden komprimerade till 1 sammanfattning; {tail_n} behållna i slutet)"

#: src/uagent/core.py:1460
msgid ""
"[WARN] history compression hit context length even at chunk_size=1; falling "
