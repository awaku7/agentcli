msgstr ""
"- Введіть рядок, що містить лише 'f', щоб увійти в режим багаторядкового "
"введення."

#: src/uagent/util_tools.py:1846
#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"  - Щоб завершити режим багаторядкового введення, введіть рядок, що точно "
"дорівнює %(sentinel)s."

