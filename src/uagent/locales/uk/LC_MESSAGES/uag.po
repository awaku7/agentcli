#: src/uagent/util_tools.py:1495
msgid "Show this help"
msgstr "Показати цю довідку"

#: src/uagent/util_tools.py:1496
msgid "Restart input from the beginning"
msgstr "Почати введення спочатку"

#: src/uagent/util_tools.py:1497
msgid "Show log file list"
msgstr "Показати список журналів"

#: src/uagent/util_tools.py:1500
msgid ""
"Change workdir without confirmation (e.g. :cd .. / :cd ~ / :cd C:\\path / "
":cd /)"
msgstr ""
"Змінити робочий каталог без підтвердження (наприклад: :cd .. / :cd ~ / :cd "
"C:\\path / :cd /)"

#: src/uagent/util_tools.py:1503
msgid "List directory entries (e.g. :ls / :ls .. / :ls ~ / :ls C:\\path)"
msgstr ""
"Показати вміст каталогу (наприклад: :ls / :ls .. / :ls ~ / :ls C:\\path)"

#: src/uagent/util_tools.py:1504
msgid "List loaded tools"
msgstr "Показати завантажені інструменти"

#: src/uagent/util_tools.py:1506
msgid "Manage/apply skills (e.g. :skills / :skills active / :skills clear)"
msgstr ""
"Керувати/застосовувати навички (наприклад: :skills / :skills active / "
":skills clear)"

#: src/uagent/util_tools.py:1508
msgid "Load a past log (overwrites current conversation history)"
msgstr "Завантажити попередній журнал (перезаписує поточну історію розмови)"

#: src/uagent/util_tools.py:1510
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Примітка: після запуску вас попросять підтвердити; "
"якщо вибрати 'y', завантажений журнал буде додано на початок поточного файлу"
" журналу сеансу (перезапис, без резервної копії)."

#: src/uagent/util_tools.py:1514
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"Видалити журнали розмов (scheck_log_*.jsonl), де кількість повідомлень "
"user/assistant/tool (без system) <= N (за замовчуванням=10)"

#: src/uagent/util_tools.py:1518
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"Стиснути історію розмов (зберегти останні N повідомлень не system; за "
"замовчуванням=40)"

#: src/uagent/util_tools.py:1522
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"Стиснути історію через підсумок LLM (старішу історію звести до 1 system-"
"повідомлення; зберегти останні N сирих; за замовчуванням=20)"

#: src/uagent/util_tools.py:1524
msgid "List long-term memory notes"
msgstr "Показати нотатки довготривалої пам'яті"

#: src/uagent/util_tools.py:1526
msgid "Delete a long-term memory note by index (see :mem-list)"
msgstr "Видалити запис довготривалої пам'яті за індексом (див. :mem-list)"

#: src/uagent/util_tools.py:1528
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr "Видалити файл(и)/каталог(и) з попереднім переглядом і підтвердженням"

#: src/uagent/util_tools.py:1530
msgid ""
"List shared long-term memory notes (requires UAGENT_SHARED_MEMORY_FILE)"
msgstr ""
"Показати нотатки спільної довготривалої пам'яті (потрібен "
"UAGENT_SHARED_MEMORY_FILE)"

#: src/uagent/util_tools.py:1532
msgid "Delete a shared long-term memory note by index"
msgstr "Видалити запис спільної довготривалої пам'яті за індексом"

#: src/uagent/util_tools.py:1534
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Встановити режим міркування (0=вимкнено, 1=низький, 2=середній, 3=високий; "
"auto/minimal/xhigh)"

#: src/uagent/util_tools.py:1536
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Встановити режим багатослівності (0=вимкнено, 1=низький, 2=середній, "
"3=високий; без аргумента=залишити)"

#: src/uagent/util_tools.py:1537
msgid "Exit"
msgstr "Вийти"

#: src/uagent/util_tools.py:1540
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr ""
"- Введіть рядок, що містить лише 'f', щоб увійти в режим багаторядкового "
"введення."

#: src/uagent/util_tools.py:1542
#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"  - Щоб завершити режим багаторядкового введення, введіть рядок, що точно "
"дорівнює %(sentinel)s."

#: src/uagent/util_tools.py:1636
msgid "Exiting."
msgstr "Вихід."

#: src/uagent/util_tools.py:1639
#, python-format
msgid "Unknown command: :%(cmd)s"
msgstr "Невідома команда: :%(cmd)s"

#: src/uagent/util_tools.py:1790
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"Наведені нижче пункти є витягами з довгострокової пам’яті цього користувача "
"(постійні нотатки). Використовуйте їх як довідкову інформацію про "
"користувача. Однак завжди віддавайте пріоритет новонаданій інформації в "
"розмові, і якщо вона суперечить старій інформації, приймайте останню "
"інформацію."

#: src/uagent/web.py:504
msgid ""
"Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"Інше завдання вже виконується в цій кімнаті. Повторіть спробу після "
"завершення."

