#: src/uagent/util_tools.py:1800
msgid "List loaded tools"
msgstr "Показати завантажені інструменти"

#: src/uagent/util_tools.py:1802
msgid "Manage/apply skills (e.g. :skills / :skills active / :skills clear)"
msgstr ""
"Керувати/застосовувати навички (наприклад: :skills / :skills active / "
":skills clear)"

#: src/uagent/util_tools.py:1804
msgid "Load a past log (overwrites current conversation history)"
msgstr "Завантажити попередній журнал (перезаписує поточну історію розмови)"

#: src/uagent/util_tools.py:1806
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Примітка: після запуску вас попросять підтвердити; "
"якщо вибрати 'y', завантажений журнал буде додано на початок поточного файлу"
" журналу сеансу (перезапис, без резервної копії)."

#: src/uagent/util_tools.py:1810
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"Видалити журнали розмов (scheck_log_*.jsonl), де кількість повідомлень "
"user/assistant/tool (без system) <= N (за замовчуванням=10)"

#: src/uagent/util_tools.py:1814
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"Стиснути історію розмов (зберегти останні N повідомлень не system; за "
"замовчуванням=40)"

#: src/uagent/util_tools.py:1818
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"Стиснути історію через підсумок LLM (старішу історію звести до 1 system-"
"повідомлення; зберегти останні N сирих; за замовчуванням=20)"

#: src/uagent/util_tools.py:1820
msgid "List long-term memory notes"
msgstr "Показати нотатки довготривалої пам'яті"

#: src/uagent/util_tools.py:1822
msgid "Delete a long-term memory note by index (see :mem-list)"
msgstr "Видалити запис довготривалої пам'яті за індексом (див. :mem-list)"

#: src/uagent/util_tools.py:1824
msgid "Copy file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Копіювати файл або каталог (підтримує -f/--overwrite і -p/--mkdirs)"

#: src/uagent/util_tools.py:1826
msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Перемістити файл або каталог (підтримує -f/--overwrite і -p/--mkdirs)"

#: src/uagent/util_tools.py:1828
msgid "Show the first n lines of a file (default=20)"
msgstr "Показати перші n рядків файлу (за замовчуванням=20)"

#: src/uagent/util_tools.py:1830
msgid "Show the last n lines of a file (default=20)"
msgstr "Показати останні n рядків файлу (за замовчуванням=20)"

#: src/uagent/util_tools.py:1832
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr "Видалити файл(и)/каталог(и) з попереднім переглядом і підтвердженням"

#: src/uagent/util_tools.py:1834
msgid ""
"List shared long-term memory notes (requires UAGENT_SHARED_MEMORY_FILE)"
msgstr ""
"Показати нотатки спільної довготривалої пам'яті (потрібен "
"UAGENT_SHARED_MEMORY_FILE)"

#: src/uagent/util_tools.py:1836
msgid "Delete a shared long-term memory note by index"
msgstr "Видалити запис спільної довготривалої пам'яті за індексом"

#: src/uagent/util_tools.py:1838
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Встановити режим міркування (0=вимкнено, 1=низький, 2=середній, 3=високий; "
"auto/minimal/xhigh)"

#: src/uagent/util_tools.py:1840
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Встановити режим багатослівності (0=вимкнено, 1=низький, 2=середній, "
"3=високий; без аргумента=залишити)"

#: src/uagent/util_tools.py:1841
msgid "Exit"
msgstr "Вийти"

#: src/uagent/util_tools.py:1844
