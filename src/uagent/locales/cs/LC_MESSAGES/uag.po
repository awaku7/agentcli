#: src/uagent/util_tools.py:1416 src/uagent/util_tools.py:1449
msgid "Shared long-term memory is not enabled (UAGENT_SHARED_MEMORY_FILE is not set)."
msgstr "Sdílená dlouhodobá paměť není povolena (UAGENT_SHARED_MEMORY_FILE není nastaveno)."

#: src/uagent/util_tools.py:1798
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory "
"(persistent memos). Use them as background information about the user. However, "
"always prioritize newly provided information in the conversation, and if it "
"contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"Níže uvedené odrážky jsou výňatky z dlouhodobé paměti tohoto uživatele (trvalé "
"poznámky). Použijte je jako podkladové informace o uživateli. V konverzaci však vždy "
"upřednostňujte nově poskytnuté informace, a pokud jsou v rozporu se staršími "
"informacemi, osvojte si nejnovější informace."

#: src/uagent/web.py:457
msgid "Another task is already running in this room. Please retry after it completes."
msgstr "V této místnosti již běží další úkol. Po dokončení to zkuste znovu."

#: src/uagent/web.py:536 src/uagent/web.py:655
msgid ""
"Environment variable UAGENT_PROVIDER is not set.\n"
"Please check environment variables when starting the web server."
msgstr ""
"Proměnná prostředí UAGENT_PROVIDER není nastavena.\n"
"Při spouštění webového serveru prosím zkontrolujte proměnné prostředí."

