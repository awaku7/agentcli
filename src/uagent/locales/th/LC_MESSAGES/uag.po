#: src/uagent/welcome.py:63
msgid "[Quick Guide]"
msgstr "[คู่มือย่อ]"

#: src/uagent/welcome.py:65
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- แชต: พิมพ์ข้อความและส่ง (GUI: ใช้ Ctrl+Enter ได้ด้วย)"

#: src/uagent/welcome.py:68
msgid "- Multiline: enter a line that is just 'f' to enter multiline mode (end with \"\"\"end)."
msgstr "- หลายบรรทัด: ป้อนบรรทัดที่มีเพียง 'f' เพื่อเข้าสู่โหมดหลายบรรทัด (จบด้วย \"\"\"end)"

#: src/uagent/welcome.py:70
msgid "- Commands: type ':help' to see system commands (log management, history compression, etc.)."
msgstr "- คำสั่ง: พิมพ์ '::help' เพื่อดูคำสั่งระบบ (จัดการ log, บีบอัดประวัติ ฯลฯ)"

#: src/uagent/welcome.py:72
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- ออก: ':exit' หรือ ':quit' เพื่อจบเซสชัน"

#: src/uagent/welcome.py:75
msgid "- Images: GUI supports drag & drop; in CUI you can input a file path for image analysis."
msgstr "- รูปภาพ: GUI รองรับลากแล้ววาง; ใน CUI คุณสามารถป้อนพาธไฟล์เพื่อวิเคราะห์รูปภาพได้"

#: src/uagent/welcome.py:78
msgid "- Docs: `uag docs` shows bundled docs; `uag docs webinspect` shows Web Inspector help (`--path/--open` also available)."
msgstr "- เอกสาร: `uag docs` แสดงเอกสารที่มากับโปรแกรม; `uag docs webinspect` แสดงวิธีใช้ Web Inspector (`--path/--open` ก็ใช้ได้)"

#: src/uagent/welcome.py:79
msgid "[Examples]"
msgstr "[ตัวอย่าง]"

#: src/uagent/welcome.py:81
msgid "- \"Analyze the source code in this folder and create a README.md.\""
msgstr "- \"วิเคราะห์ซอร์สโค้ดในโฟลเดอร์นี้และสร้าง README.md\""

#: src/uagent/welcome.py:83
msgid "- \"Take a screenshot of the current desktop and describe the visible window contents.\""
msgstr "- \"ถ่ายภาพหน้าจอเดสก์ท็อปปัจจุบันและอธิบายเนื้อหาที่เห็นในหน้าต่าง\""

#: src/uagent/welcome.py:84
msgid "- \"Create a monthly summary report from this Excel file.\""
msgstr "- \"สร้างรายงานสรุปรายเดือนจากไฟล์ Excel นี้\""

#: src/uagent/welcome.py:85
msgid "- \"Read this PDF and list three key points.\""
msgstr "- \"อ่าน PDF นี้และสรุป 3 ประเด็นสำคัญ\""

msgid "- \"Search the latest news and summarize a specific topic.\""
msgstr "- \"ค้นหาข่าวล่าสุดและสรุปหัวข้อที่ระบุ\""
