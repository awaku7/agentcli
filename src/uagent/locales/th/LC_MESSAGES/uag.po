msgstr "ไม่ได้ตั้งค่าตัวแปรสภาพแวดล้อม %(name)s"

#: src/uagent/core.py:554
#, python-format
msgid "No log files found."
msgstr "ไม่พบไฟล์บันทึก"

#: src/uagent/core.py:557
msgid "logs: showing %(shown)d/%(total)d (dir=%(dir)s)"
msgstr "logs: แสดง %(shown)d/%(total)d (dir=%(dir)s)"

#: src/uagent/core.py:957
msgid "Log files:"
msgstr "ไฟล์บันทึก:"

#: src/uagent/core.py:991
#, python-format
msgid ""
"- Summarize the conversation log so far in English.\n"
"- Keep the summary concise but include key decisions, constraints, and pending items.\n"
"- Output should be directly usable as a system message titled 'Summary of the conversation so far'.\n"
msgstr ""
"- สรุปบันทึกการสนทนาจนถึงตอนนี้เป็นภาษาอังกฤษ\n"
"- ให้สรุปกระชับแต่รวมการตัดสินใจสำคัญ ข้อจำกัด และงานค้าง\n"
"- เอาต์พุตควรใช้งานได้ทันทีเป็นข้อความ system ชื่อ 'Summary of the conversation so far'\n"

#: src/uagent/core.py:1009
msgid "Error while calling LLM for history compression: %(err)r"
msgstr "เกิดข้อผิดพลาดขณะเรียก LLM เพื่อบีบอัดประวัติ: %(err)r"

#: src/uagent/core.py:1017
#, python-brace-format
msgid ""
"Summary of the conversation so far:\n"
msgstr ""
"สรุปการสนทนาจนถึงตอนนี้:\n"

#: src/uagent/core.py:1032
msgid "[INFO] Conversation history was summarized by the LLM: old_part={old_n} -> 1 summary + tail_part={tail_n}"
msgstr "[INFO] ประวัติการสนทนาถูกสรุปโดย LLM: old_part={old_n} -> 1 summary + tail_part={tail_n}"

#: src/uagent/core.py:1033
msgid "Available commands:"
msgstr "คำสั่งที่ใช้ได้:"

#: src/uagent/core.py:1034
msgid "  :help                 Show this help"
msgstr "  :help                 แสดงความช่วยเหลือ"

#: src/uagent/core.py:1035
msgid "  (in multiline input) \"\"\"retry  Restart input from the beginning"
msgstr "  (ในโหมดป้อนหลายบรรทัด) \"\"\"retry  เริ่มป้อนใหม่ตั้งแต่ต้น"

#: src/uagent/core.py:1037
msgid "  :logs / :list         Show log file list"
msgstr "  :logs / :list         แสดงรายการไฟล์บันทึก"

#: src/uagent/core.py:1040
msgid "  :cd <path>            Change workdir without confirmation (e.g. :cd .. / :cd ~ / :cd C:\\path / :cd /)"
msgstr "  :cd <path>            เปลี่ยน workdir โดยไม่ต้องยืนยัน (เช่น :cd .. / :cd ~ / :cd C:\\path / :cd /)"

#: src/uagent/core.py:1043
msgid "  :ls [path]            List directory entries (e.g. :ls / :ls .. / :ls ~ / :ls C:\\path)"
msgstr "  :ls [path]            แสดงรายการไฟล์/โฟลเดอร์ (เช่น :ls / :ls .. / :ls ~ / :ls C:\\path)"

#: src/uagent/core.py:1046
msgid "  :load <idx|path>      Load a past log (overwrites current conversation history)"
msgstr "  :load <idx|path>      โหลดบันทึกเก่า (เขียนทับประวัติการสนทนาปัจจุบัน)"

#: src/uagent/core.py:1049
msgid "                       Note: after running, you will be asked for confirmation; choosing 'y' prepends the loaded log into the current session log file (overwrite, no backup)."
msgstr "                       หมายเหตุ: หลังจากรันแล้ว จะมีการขอให้ยืนยัน; หากเลือก 'y' จะนำบันทึกที่โหลดมาไปไว้ต้นไฟล์ log ของเซสชันปัจจุบัน (เขียนทับ, ไม่มีสำรอง)"

#: src/uagent/core.py:1052
msgid "  :clean [N]            Delete conversation logs (scheck_log_*.jsonl) where the count of user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr "  :clean [N]            ลบไฟล์บันทึกการสนทนา (scheck_log_*.jsonl) ที่จำนวนข้อความ user/assistant/tool (ไม่นับ system) <= N (ค่าเริ่มต้น=10)"

#: src/uagent/core.py:1055
msgid "  :shrink [N]           Shrink conversation history (keep last N non-system messages; default=40)"
msgstr "  :shrink [N]           ย่อประวัติการสนทนา (เก็บข้อความที่ไม่ใช่ system ล่าสุด N รายการ; ค่าเริ่มต้น=40)"

#: src/uagent/core.py:1057
msgid "  :shrink_llm [N]       Shrink history via LLM summarization (summarize older history into 1 system message; keep last N raw; default=20)"
msgstr "  :shrink_llm [N]       ย่อประวัติด้วยการสรุปโดย LLM (สรุปประวัติเก่าเป็น 1 ข้อความ system; เก็บข้อความดิบล่าสุด N รายการ; ค่าเริ่มต้น=20)"

#: src/uagent/core.py:1059
msgid "  :mem-list             List long-term memory notes"
msgstr "  :mem-list             แสดงรายการบันทึกหน่วยความจำระยะยาว"

#: src/uagent/core.py:1062
msgid "  :mem-del <index>      Delete a long-term memory note by index (see :mem-list)"
msgstr "  :mem-del <index>      ลบบันทึกหน่วยความจำระยะยาวตาม index (ดู :mem-list)"

#: src/uagent/core.py:1064
msgid "  :shared-mem-list      List shared long-term memory notes (requires UAGENT_SHARED_MEMORY_FILE)"
msgstr "  :shared-mem-list      แสดงรายการบันทึกหน่วยความจำระยะยาวแบบแชร์ (ต้องมี UAGENT_SHARED_MEMORY_FILE)"

#: src/uagent/core.py:1066
msgid "  :shared-mem-del <i>   Delete a shared long-term memory note by index"
msgstr "  :shared-mem-del <i>   ลบบันทึกหน่วยความจำระยะยาวแบบแชร์ตาม index"

#: src/uagent/core.py:1069
msgid "  :r [0|1|2|3|auto|minimal|xhigh]  Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr "  :r [0|1|2|3|auto|minimal|xhigh]  ตั้งค่าโหมด reasoning (0=ปิด, 1=ต่ำ, 2=ปานกลาง, 3=สูง; auto/minimal/xhigh)"

#: src/uagent/core.py:1071
msgid "  :v [0|1|2|3]          Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=cycle)"
msgstr "  :v [0|1|2|3]          ตั้งค่าโหมด verbosity (0=ปิด, 1=ต่ำ, 2=ปานกลาง, 3=สูง; ไม่ระบุ=สลับวน)"

#: src/uagent/core.py:1073
msgid "  :exit / :quit         Exit"
msgstr "  :exit / :quit         ออก"

#: src/uagent/core.py:1074
msgid "Hints:"
msgstr "คำแนะนำ:"

#: src/uagent/core.py:1075
#, python-format
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr "  - ป้อนบรรทัดที่มีเพียง 'f' เพื่อเข้าสู่โหมดป้อนหลายบรรทัด"

#: src/uagent/core.py:1115
msgid "  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr "  - เพื่อจบโหมดป้อนหลายบรรทัด ให้ป้อนบรรทัดที่ตรงกับ %(sentinel)s เท่านั้น"

