msgid "Load a past log (overwrites current conversation history)"
msgstr "Загрузить прошлый журнал (перезаписывает текущую историю беседы)"

#: src/uagent/util_tools.py:1890
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Примечание: после запуска будет запрошено "
