msgstr "После завершения всегда вызывайте `finish_skill`, если это возможно.\n"

#: src/uagent/util_tools.py:1155
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"Выберите номер skill для запуска. Введите c, чтобы отменить.\n"
"Подсказка: :skills clear  (удалить применённые skill)\n"
"Введите номер:"

#: src/uagent/util_tools.py:1191
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Запустить этот навык как системную инструкцию и оставить его активным в этом сеансе?\n"
"\n"
"Имя: %(name)s\n"
"Путь: %(path)s\n"
"\n"
"Продолжить? Введите y, чтобы запустить, или c, чтобы отменить."

#: src/uagent/util_tools.py:1254
#, python-format
msgid ""
"[clean] Invalid argument: %(arg)r (specify number=threshold; default is "
"%(default)d)"
msgstr ""
"[clean] Неверный аргумент: %(arg)r (укажите number=threshold; по умолчанию "
"%(default)d)"

#: src/uagent/util_tools.py:1303
#, python-format
msgid ""
"will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"удалит файлы журналов разговоров (scheck_log_*.jsonl) с диска.\n"
"Каталог журналов: %(dir)s\n"
"Правило: общее число сообщений user/assistant/tool без system <= %(threshold)d\n"
"Целей: %(n)d\n"
"\n"
"Продолжить? Введите y для запуска или c для отмены."

#: src/uagent/util_tools.py:1371
msgid " - (%(count)d msgs) %(path)s"
msgstr " - (%(count)d сообщений) %(path)s"

#: src/uagent/util_tools.py:1415
#, python-format
msgid ""
"will overwrite the current session log file and prepend the loaded log (no backup).\n"
"\n"
"Current log: %(cur_log)s\n"
"Source log: %(src_log)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"перезапишет текущий файл журнала сеанса и добавит загруженный журнал в начало (без резервной копии).\n"
"\n"
"Текущий журнал: %(cur_log)s\n"
"Исходный журнал: %(src_log)s\n"
"\n"
"Продолжить? Введите y для запуска или c для отмены."

#: src/uagent/util_tools.py:1546
#, python-brace-format
msgid ""
"Delete {count} path(s)?\n"
"\n"
"{paths}\n"
"\n"
"Enter y to proceed, or c to cancel."
msgstr ""
"Удалить {count} путь(ей)?\n"
"\n"
"{paths}\n"
"\n"
"Введите y, чтобы продолжить, или c, чтобы отменить."

#: src/uagent/util_tools.py:1603
#, python-format
msgid "Specified index %(idx)d is out of range."
msgstr "Указанный индекс %(idx)d вне диапазона."

#: src/uagent/util_tools.py:1612
#, python-format
msgid "Log file not found: %(path)s"
msgstr "Файл журнала не найден: %(path)s"

