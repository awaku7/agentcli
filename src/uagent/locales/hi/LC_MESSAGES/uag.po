#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[त्वरित मार्गदर्शिका]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- चैट: एक संदेश टाइप करें और भेजें (GUI: Ctrl+Enter भी उपलब्ध है)।"

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- मल्टीलाइन: मल्टीलाइन मोड में प्रवेश करने के लिए एक पंक्ति दर्ज करें जो "
"सिर्फ 'एफ' है (अंत में \"\"\"अंत)।"

msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.). Note: commands start with ':' (colon) instead of '/' "
"(slash)."
msgstr "- कमांड: सिस्टम कमांड (लॉग प्रबंधन, इतिहास संपीड़न, आदि) देखने के लिए ':help' टाइप करें। नोट: कमांड '/' (स्लैश) के बजाय ':' (कोलन) से शुरू होते हैं।"

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- बाहर निकलें: ': बाहर निकलें' या ': छोड़ें' से सत्र समाप्त होता है।"

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- छवियां: जीयूआई ड्रैग एंड ड्रॉप का समर्थन करता है; सीयूआई में आप छवि "
"विश्लेषण के लिए फ़ाइल पथ इनपुट कर सकते हैं।"

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs: `%(docs_cmd)s` शामिल दस्तावेज़ दिखाता है; `%(webinspect_cmd)s` Web "
"Inspector सहायता दिखाता है (`--path/--open` भी उपलब्ध हैं)।"

