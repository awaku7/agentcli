#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[त्वरित मार्गदर्शिका]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- चैट: एक संदेश टाइप करें और भेजें (GUI: Ctrl+Enter भी उपलब्ध है)।"

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- मल्टीलाइन: मल्टीलाइन मोड में प्रवेश करने के लिए एक पंक्ति दर्ज करें जो "
"सिर्फ 'एफ' है (अंत में \"\"\"अंत)।"

#: src/uagent/welcome.py:68
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.)."
msgstr ""
"- कमांड: सिस्टम कमांड (लॉग प्रबंधन, इतिहास संपीड़न, आदि) देखने के लिए "
"':help' टाइप करें।"

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- बाहर निकलें: ': बाहर निकलें' या ': छोड़ें' से सत्र समाप्त होता है।"

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- छवियां: जीयूआई ड्रैग एंड ड्रॉप का समर्थन करता है; सीयूआई में आप छवि "
"विश्लेषण के लिए फ़ाइल पथ इनपुट कर सकते हैं।"

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `uag docs` shows bundled docs; `uag docs webinspect` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- दस्तावेज़: `uag दस्तावेज़` बंडल किए गए दस्तावेज़ दिखाता है; `uag डॉक्स "
"वेबइंस्पेक्ट` वेब इंस्पेक्टर सहायता दिखाता है (`--path/--open` भी उपलब्ध "
"है)।"

#: src/uagent/welcome.py:78
msgid "[Examples]"
msgstr "[उदाहरण]"

#: src/uagent/welcome.py:79
msgid "- \"Analyze the source code in this folder and create a README.md.\""
msgstr "- \"इस फ़ोल्डर में स्रोत कोड का विश्लेषण करें और एक README.md बनाएं।\""

#: src/uagent/welcome.py:81
msgid ""
"- \"Take a screenshot of the current desktop and describe the visible window"
" contents.\""
msgstr ""
"- \"वर्तमान डेस्कटॉप का स्क्रीनशॉट लें और दृश्यमान विंडो सामग्री का वर्णन "
"करें।\""

#: src/uagent/welcome.py:83
msgid "- \"Create a monthly summary report from this Excel file.\""
msgstr "- \"इस एक्सेल फ़ाइल से एक मासिक सारांश रिपोर्ट बनाएं।\""

#: src/uagent/welcome.py:84
msgid "- \"Read this PDF and list three key points.\""
msgstr "- \"इस पीडीएफ को पढ़ें और तीन मुख्य बिंदु सूचीबद्ध करें।\""

#: src/uagent/welcome.py:85
msgid "- \"Search the latest news and summarize a specific topic.\""
msgstr "- \"नवीनतम समाचार खोजें और किसी विशिष्ट विषय का सारांश प्रस्तुत करें।\""

