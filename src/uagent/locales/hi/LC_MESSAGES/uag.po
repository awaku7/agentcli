#~ "(अधिलेखन, कोई बैकअप नहीं)।"

#~ msgid ""
#~ "  :clean [N]            Delete conversation logs (scheck_log_*.jsonl) where "
#~ "the count of user/assistant/tool messages (excluding system) is <= N "
#~ "(default=10)"
#~ msgstr ""
#~ "  :clean [N]            वार्तालाप लॉग (scheck_log_*.jsonl) हटाएँ, जहाँ "
#~ "user/assistant/tool संदेशों की संख्या (system को छोड़कर) <= N हो "
#~ "(डिफ़ॉल्ट=10)"

#~ msgid ""
#~ "  :shrink [N]           Shrink conversation history (keep last N non-system "
#~ "messages; default=40)"
#~ msgstr ""
#~ "  :shrink [N]           वार्तालाप इतिहास छोटा करें (अंतिम N गैर-प्रणाली "
#~ "संदेश रखें; डिफ़ॉल्ट=40)"

#~ msgid ""
#~ "  :shrink_llm [N]       Shrink history via LLM summarization (summarize "
#~ "older history into 1 system message; keep last N raw; default=20)"
#~ msgstr ""
#~ "  :shrink_llm [N]       LLM सारांश से इतिहास छोटा करें (पुराने इतिहास को 1 "
#~ "प्रणाली संदेश में सारांशित करें; अंतिम N को कच्चा रखें; डिफ़ॉल्ट=20)"

