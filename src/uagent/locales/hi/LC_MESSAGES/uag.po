msgstr " - (%(count)d संदेश) %(path)s"

#: src/uagent/util_tools.py:1415
#, python-format
msgid ""
"will overwrite the current session log file and prepend the loaded log (no backup).\n"
"\n"
"Current log: %(cur_log)s\n"
"Source log: %(src_log)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"वर्तमान सत्र लॉग फ़ाइल को अधिलेखित किया जाएगा और लोड किया गया लॉग शुरुआत में जोड़ा जाएगा (कोई बैकअप नहीं)।\n"
"\n"
"वर्तमान लॉग: %(cur_log)s\n"
"स्रोत लॉग: %(src_log)s\n"
"\n"
"जारी रखें? चलाने के लिए y, रद्द करने के लिए c।"

