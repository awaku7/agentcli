msgstr "uagent আরম্ভ ব্যর্থ হয়েছে: %(err)s"

msgid "uagent execution failed: %(etype)s: %(err)s"
msgstr "uagent এক্সিকিউশন ব্যর্থ হয়েছে: %(etype)s: %(err)s"

msgid "Unknown UAGENT_A2A_ENGINE: %(mode)s"
msgstr "অজানা UAGENT_A2A_ENGINE: %(mode)s৷"
