#: src/uagent/setup_cli.py:1537
msgid "Cancelled."
msgstr "বাতিল করা হয়েছে।"

#: src/uagent/cli.py:726 src/uagent/cli.py:781
msgid "Received multiline reply."
msgstr "বহু-লাইন উত্তর পাওয়া গেছে।"

#: src/uagent/cli.py:734 src/uagent/cli.py:816
#, python-format
msgid ""
"(Multiline input mode: enter the body in multiple lines; to restart, type "
"\"\"\"retry; finish with a line containing %(sentinel)s)"
msgstr ""
"(বহু-লাইন ইনপুট মোড: বডি একাধিক লাইনে লিখুন; পুনরায় শুরু করতে \"\"\"retry "
"টাইপ করুন; %(sentinel)s থাকা একটি লাইন দিয়ে শেষ করুন)(মাল্টিলাইন ইনপুট মোড:"
" একাধিক লাইনে বডি প্রবেশ করান; রিস্টার্ট করতে, টাইপ করুন \"\"\"পুনরায় "
"চেষ্টা করুন; %(sentinel)s সমন্বিত একটি লাইন দিয়ে শেষ করুন)"

#: src/uagent/cli.py:770 src/uagent/cli.py:833
msgid "Discarded previous input. Please start over."
msgstr "পূর্ববর্তী ইনপুট বাতিল করা হয়েছে। আবার শুরু করুন।"

#: src/uagent/cli.py:955
msgid ""
"Image file paths were found in your input.\n"
"Do you want to send these images to the LLM (external API) for analysis?\n"
"\n"
msgstr ""
"ইমেজ ফাইল পাথ আপনার ইনপুট পাওয়া গেছে.\n"
"আপনি বিশ্লেষণের জন্য LLM (বাহ্যিক API) এই ছবি পাঠাতে চান?"

#: src/uagent/cli.py:961
msgid "Reply with y to send, or n (or c/cancel) to skip sending."
msgstr ""
"পাঠাতে y দিয়ে উত্তর দিন, অথবা পাঠানো এড়াতে n (অথবা c/cancel) দিন।পাঠাতে y "
"দিয়ে উত্তর দিন, অথবা পাঠানো এড়িয়ে যেতে n (বা c/বাতিল) দিয়ে উত্তর দিন।"

#: src/uagent/cli.py:979
#, python-format
msgid ""
"Image send confirmation failed; will not send images: %(etype)s: %(err)s"
msgstr ""
"ছবি পাঠানোর নিশ্চিতকরণ ব্যর্থ হয়েছে; ছবি পাঠানো হবে না: %(etype)s: "
"%(err)sছবি পাঠাতে নিশ্চিতকরণ ব্যর্থ হয়েছে; ছবি পাঠাবে না: %(etype)s: "
"%(err)s"

#: src/uagent/cli.py:1007 src/uagent/scheckgui.py:432
#, python-format
msgid "Failed to attach image: %(path)s (%(etype)s: %(err)s)"
msgstr "ছবি সংযুক্ত করতে ব্যর্থ হয়েছে: %(path)s (%(etype)s: %(err)s)"

#: src/uagent/cli.py:1044
#, python-format
msgid "Unknown event kind=%(kind)r: %(ev)r"
msgstr "অজানা ইভেন্টের ধরন=%(kind)r: %(ev)r"

#: src/uagent/cli.py:1062
msgid "Exited uag."
msgstr "প্রস্থান করা হয়েছে uag."

#: src/uagent/cli_docs.py:33
msgid "[docs] name is required"
msgstr "[ডক্স] নাম প্রয়োজন"

#: src/uagent/cli_startup.py:22
msgid "[INFO] startup genre prompt = numeric-input"
msgstr "[INFO] স্টার্টআপ জেনার প্রম্পট = numeric-input"

msgid ""
"Enter the sum of numbers "
"(1=basic,2=comm,4=office,8=devel,16=iot,32=exec,64=external,128=media,255=all,"
" Enter=enable all):"
msgstr ""
"সংখ্যার যোগফল লিখুন "
"(1=মৌলিক,2=যোগাযোগ,4=অফিস,8=ডেভেলপ,16=আইওটি,32=এক্সিকিউট,64=বাহ্যিক,128=মিডিয়া,255=সব,"
" Enter=সব সক্রিয়):"

msgid "Basic (file, env, time, prompts, skills, memory, tools control)"
msgstr "মৌলিক (ফাইল, পরিবেশ, সময়, প্রম্পট, দক্ষতা, মেমরি, টুল নিয়ন্ত্রণ)"

#: src/uagent/cli_startup.py:70 src/uagent/scheckgui.py:985
#: src/uagent/web.py:940
