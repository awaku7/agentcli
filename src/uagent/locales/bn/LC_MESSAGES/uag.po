#: src/uagent/checks.py:17 src/uagent/checks.py:27
#, python-format
msgid "Please install Git. See: %(url)s"
msgstr "অনুগ্রহ করে Git ইনস্টল করুন। দেখুন: %(url)s"

#: src/uagent/checks.py:20
msgid ""
"Please install Git. Example: sudo apt install git (Ubuntu/Debian) or sudo "
"yum install git (CentOS/RHEL)"
msgstr ""
"অনুগ্রহ করে গিট ইনস্টল করুন। উদাহরণ: sudo apt install git (Ubuntu/Debian) "
"অথবা sudo yum install git (CentOS/RHEL)অনুগ্রহ করে গিট ইন্সটল করুন। উদাহরণ: "
"sudo apt install git (Ubuntu/Debian) বা sudo yum install git (CentOS/RHEL)"

#: src/uagent/checks.py:23
msgid ""
"Please install Git. If using Homebrew: brew install git, or install Xcode "
"Command Line Tools: xcode-select --install"
msgstr ""
"অনুগ্রহ করে গিট ইনস্টল করুন। Homebrew ব্যবহার করলে: brew install git, অথবা "
"Xcode Command Line Tools ইনস্টল করুন: xcode-select --installঅনুগ্রহ করে গিট "
"ইন্সটল করুন। হোমব্রু ব্যবহার করলে: brew install git, অথবা Xcode কমান্ড লাইন "
"টুল ইনস্টল করুন: xcode-select --install"

#: src/uagent/checks.py:30
msgid "[ERROR] Git is not installed."
msgstr "[ত্রুটি] Git ইনস্টল করা নেই।"

#: src/uagent/cli.py:465
msgid "getch() fallback to input()"
msgstr "getch() ব্যর্থ হলে input() ব্যবহার করা হবে"

#: src/uagent/cli.py:682
msgid "Received Ctrl+C. Starting shutdown..."
msgstr "Ctrl+C গ্রহণ করা হয়েছে। বন্ধ করা হচ্ছে..."

#: src/uagent/cli.py:719 src/uagent/cli.py:764 src/uagent/setup_cli.py:1258
#: src/uagent/setup_cli.py:1277 src/uagent/setup_cli.py:1300
