"Development (lint, test, git, DB, screenshot, browser, binary, compile)"
msgstr ""
"Development (lint, test, git, DB, স্ক্রিনশট, browser, binary, compile)"

#: src/uagent/cli_startup.py:80 src/uagent/scheckgui.py:1003
