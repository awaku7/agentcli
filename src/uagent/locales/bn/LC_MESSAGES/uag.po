#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[দ্রুত নির্দেশিকা]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr ""
"- চ্যাট: একটি বার্তা টাইপ করে পাঠান (GUI: Ctrl+Enter-ও ব্যবহার করা যায়)।- "
"চ্যাট: একটি বার্তা টাইপ করুন এবং পাঠান (GUI: Ctrl+Enter এছাড়াও উপলব্ধ)।"

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- মাল্টিলাইন: মাল্টিলাইন মোডে প্রবেশ করার জন্য একটি লাইন লিখুন যা শুধু 'f' "
"হয় (\"\"\"শেষ দিয়ে শেষ করুন)।"

#: src/uagent/welcome.py:68
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.)."
msgstr ""
"- কমান্ড: সিস্টেম কমান্ড (লগ পরিচালনা, ইতিহাস সংকোচন, ইত্যাদি) দেখতে ':help'"
" টাইপ করুন।"

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- প্রস্থান করুন: ': exit' বা ': quit' সেশন শেষ করে।"

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- ইমেজ: GUI টেনে আনে এবং ড্রপ সমর্থন করে; CUI-তে আপনি চিত্র বিশ্লেষণের জন্য "
"একটি ফাইল পাথ ইনপুট করতে পারেন।"

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- ডক্স: `%(docs_cmd)s` বান্ডেল করা ডক্স দেখায়; `%(webinspect_cmd)s` Web "
"Inspector-এর সাহায্য দেখায় (`--path/--open`ও উপলব্ধ)।- ডক্স: `%(docs_cmd)s`"
" বান্ডিল ডক্স দেখায়; `%(webinspect_cmd)s` ওয়েব ইন্সপেক্টর সহায়তা দেখায় "
"(`--পাথ/--ওপেন`ও উপলব্ধ)।"

#: src/uagent/welcome.py:79
msgid "[Examples]"
msgstr "[উদাহরণ]"

#: src/uagent/welcome.py:80
msgid "- \"Analyze the source code in this folder and create a README.md.\""
msgstr "- \"এই ফোল্ডারে সোর্স কোড বিশ্লেষণ করুন এবং একটি README.md তৈরি করুন।\""

#: src/uagent/welcome.py:82
msgid ""
"- \"Take a screenshot of the current desktop and describe the visible window"
" contents.\""
msgstr ""
"- \"বর্তমান ডেস্কটপের একটি স্ক্রিনশট নিন এবং দৃশ্যমান উইন্ডোর বিষয়বস্তু "
"বর্ণনা করুন।\""

#: src/uagent/welcome.py:84
msgid "- \"Create a monthly summary report from this Excel file.\""
msgstr "- \"এই এক্সেল ফাইল থেকে একটি মাসিক সারসংক্ষেপ প্রতিবেদন তৈরি করুন।\""

#: src/uagent/welcome.py:85
msgid "- \"Read this PDF and list three key points.\""
msgstr "- \"এই পিডিএফটি পড়ুন এবং তিনটি মূল পয়েন্ট তালিকাভুক্ত করুন।\""

#: src/uagent/welcome.py:86
msgid "- \"Search the latest news and summarize a specific topic.\""
msgstr ""
"- \"সর্বশেষ খবর অনুসন্ধান করুন এবং একটি নির্দিষ্ট বিষয়ের সারসংক্ষেপ করুন।\""

