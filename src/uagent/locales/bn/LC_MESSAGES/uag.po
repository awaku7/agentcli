msgstr "OpenRouter ফলব্যাক মডেল সক্রিয় করা হয়েছে।"

#: src/uagent/cli_startup.py:339
#, python-format
msgid "current workdir = %(cwd)s"
msgstr "বর্তমান workdir = %(cwd)s"

#: src/uagent/cli_startup.py:352 src/uagent/scheckgui.py:307
msgid "Loaded long-term memory."
msgstr "দীর্ঘমেয়াদি মেমরি লোড করা হয়েছে।"

#: src/uagent/cli_startup.py:365 src/uagent/scheckgui.py:320
msgid "Loaded shared long-term memory."
msgstr "শেয়ার করা দীর্ঘমেয়াদি মেমরি লোড করা হয়েছে।"

#: src/uagent/cli_startup.py:372 src/uagent/web.py:718
#, python-format
msgid ""
"[WARN] Exception occurred while loading shared long-term memory: %(err)s"
msgstr ""
"[সতর্কতা] শেয়ার করা দীর্ঘমেয়াদি মেমরি লোড করার সময় ব্যতিক্রম ঘটেছে: "
"%(err)s[সতর্কতা] শেয়ার করা দীর্ঘমেয়াদি মেমরি লোড করার সময় ব্যতিক্রম "
"ঘটেছে: %(err)s"

#: src/uagent/cli_startup.py:406
#, python-format
msgid "[WARN] Failed to read startup file: %(path)s (%(err)s)"
msgstr "[সতর্ক] স্টার্টআপ ফাইল পড়তে ব্যর্থ হয়েছে: %(path)s (%(err)s)"

#: src/uagent/cli_startup.py:420
#, python-format
msgid "Startup file provided: %(path)s"
msgstr "স্টার্টআপ ফাইল দেওয়া হয়েছে: %(path)s"

#: src/uagent/cli_startup.py:443
msgid "--non-interactive was specified; exiting without waiting for stdin."
msgstr ""
"--non-interactive নির্দিষ্ট করা হয়েছে; stdin-এর জন্য অপেক্ষা না করে "
"প্রস্থান করা হচ্ছে।--অ-ইন্টারেক্টিভ নির্দিষ্ট করা হয়েছে; stdin এর জন্য "
"অপেক্ষা না করে প্রস্থান করা হচ্ছে।"

#: src/uagent/core.py:290 src/uagent/core.py:311
#, python-format
msgid "Environment variable %(name)s is not set."
msgstr "এনভায়রনমেন্ট ভেরিয়েবল %(নাম) সেট করা নেই।"

#: src/uagent/core.py:611
msgid "No log files found."
msgstr "কোন লগ ফাইল পাওয়া যায়নি."

#: src/uagent/core.py:629
msgid "(unknown time)"
msgstr "(অজানা সময়)"

#: src/uagent/core.py:632
#, python-format
msgid "logs: showing %(shown)d/%(total)d (dir=%(dir)s)"
msgstr "লগ: দেখানো হচ্ছে %(shown)d/%(total)d (dir=%(dir)s)"

#: src/uagent/core.py:635
msgid "Log files:"
msgstr "লগ ফাইল:"

#: src/uagent/core.py:642
msgid "(mtime unknown)"
msgstr "(সংশোধনের সময় অজানা)"

#: src/uagent/core.py:760 src/uagent/core.py:763
msgid "(no user message)"
msgstr "(কোন ব্যবহারকারীর বার্তা নেই)"

#: src/uagent/core.py:768
#, python-format
msgid ""
"[%(idx)d] %(mtime_text)s | %(turns)d msgs | first: %(first_user)s | last: "
"%(last_user)s"
msgstr ""
"[%(idx)d] %(mtime_text)s | %(turns)dটি বার্তা | প্রথম: %(first_user)s | শেষ:"
" %(last_user)s"

#: src/uagent/core.py:1020
#, python-format
msgid ""
"[INFO] There were %(count)d messages to compress, so nothing was changed."
msgstr ""
"[INFO] সংকোচনের জন্য %(count)dটি বার্তা ছিল, তাই কিছুই পরিবর্তন করা হয়নি।"

#: src/uagent/core.py:1031
#, python-format
msgid ""
"[INFO] Compressed in-memory conversation history: %(old_n)d -> %(new_n)d "
"messages (keep_last=%(keep_last)d)"
msgstr ""
"[INFO] মেমরিতে থাকা কথোপকথনের ইতিহাস সংকুচিত করা হয়েছে: %(old_n)d -> "
"%(new_n)dটি বার্তা (keep_last=%(keep_last)d)"

#: src/uagent/core.py:1336
msgid "429 retry limit (%(max_retries)s) reached while history compression."
msgstr ""
"ইতিহাস সংকোচনের সময় 429 পুনঃপ্রচেষ্টার সীমা (%(max_retries)s) পৌঁছেছে।"

#: src/uagent/core.py:1346
msgid "Error while calling LLM for history compression: %(err)r"
msgstr "ইতিহাস সংকোচনের জন্য LLM কল করার সময় ত্রুটি: %(err)r"

#: src/uagent/core.py:1379
msgid "- Summarize the conversation chunk in English.\n"
msgstr "- কথোপকথনের অংশটি ইংরেজিতে সংক্ষেপ করুন।\n"

#: src/uagent/core.py:1381
msgid ""
"- Keep the summary concise but include key decisions, constraints, and "
"pending items.\n"
msgstr ""
"- সংক্ষেপটি সংক্ষিপ্ত রাখুন তবে মূল সিদ্ধান্ত, সীমাবদ্ধতা এবং মুলতুবি থাকা "
"বিষয়গুলি অন্তর্ভুক্ত করুন।\n"

#: src/uagent/core.py:1383
msgid "- Output should be directly usable as a system message."
msgstr "- আউটপুটটি সরাসরি সিস্টেম বার্তা হিসাবে ব্যবহারযোগ্য হওয়া উচিত।"

#: src/uagent/core.py:1386
msgid "Conversation chunk:\n"
msgstr "কথোপকথনের অংশ:\n"

#: src/uagent/core.py:1388
msgid "Write a concise summary of this chunk."
msgstr "এই অংশের একটি সংক্ষিপ্ত সারসংক্ষেপ লিখুন।"

#: src/uagent/core.py:1392
msgid "- You are updating an existing conversation summary.\n"
msgstr "- আপনি একটি বিদ্যমান কথোপকথনের সারসংক্ষেপ আপডেট করছেন।\n"

#: src/uagent/core.py:1393
msgid "- Preserve important facts from the previous summary.\n"
msgstr "- পূর্ববর্তী সারসংক্ষেপ থেকে গুরুত্বপূর্ণ তথ্যগুলি সংরক্ষণ করুন।\n"

#: src/uagent/core.py:1395
msgid ""
"- Merge in the new chunk without losing constraints, decisions, or pending "
"items.\n"
msgstr ""
"- সীমাবদ্ধতা, সিদ্ধান্ত বা মুলতুবি থাকা বিষয়গুলি না হারিয়ে নতুন অংশটি "
"মার্জ করুন।\n"

#: src/uagent/core.py:1397
msgid "- Keep the result concise and suitable for a system message."
