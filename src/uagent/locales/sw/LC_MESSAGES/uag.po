#: src/uagent/util_tools.py:1413 src/uagent/util_tools.py:1446
msgid ""
"Shared long-term memory is not enabled (UAGENT_SHARED_MEMORY_FILE is not "
"set)."
msgstr ""
"Kumbukumbu ya muda mrefu ya pamoja haijawezeshwa (UAGENT_SHARED_MEMORY_FILE "
"haijawekwa)."

#: src/uagent/util_tools.py:1793
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"Vipengele vya orodha vilivyo hapa chini ni dondoo kutoka kumbukumbu ya muda mrefu ya mtumiaji huyu (memo za kudumu). Vitumie kama taarifa ya msingi kuhusu mtumiaji. Hata hivyo, daima zingatia taarifa mpya zilizotolewa katika mazungumzo, na ikiwa zinapingana na taarifa za zamani, chukua taarifa ya hivi karibuni.\n"
"\n"

#: src/uagent/web.py:504
msgid ""
"Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"Kazi nyingine tayari inaendelea katika chumba hiki. Tafadhali jaribu tena "
"baada ya kukamilika."

#: src/uagent/web.py:592 src/uagent/web.py:761
msgid ""
"Environment variable UAGENT_PROVIDER is not set.\n"
"Please check environment variables when starting the web server."
msgstr ""
"Kigezo cha mazingira UAGENT_PROVIDER hakijawekwa.\n"
"Tafadhali angalia vigezo vya mazingira unapoanzisha seva ya wavuti."

