msgstr "Dhibiti/tumia ujuzi (mf. :skills / :skills active / :skills clear)"

#: src/uagent/util_tools.py:1836
msgid "Load a past log (overwrites current conversation history)"
msgstr "Pakia logi ya awali (itaandika upya historia ya mazungumzo ya sasa)"

#: src/uagent/util_tools.py:1838
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Kumbuka: baada ya kuendesha, utaombwa uthibitisho; "
"ukichagua 'y', logi iliyopakiwa itawekwa mwanzo wa faili ya logi ya kipindi "
"cha sasa (itaandika upya, bila chelezo)."

#: src/uagent/util_tools.py:1842
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"Futa logi za mazungumzo (scheck_log_*.jsonl) ambapo idadi ya ujumbe wa "
"mtumiaji/msaidizi/zana (bila system) ni <= N (chaguo-msingi=10)"

#: src/uagent/util_tools.py:1846
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"Punguza historia ya mazungumzo (hifadhi ujumbe wa mwisho N usio wa system; "
"chaguo-msingi=40)"

#: src/uagent/util_tools.py:1850
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"Punguza historia kwa muhtasari wa LLM (fanya muhtasari wa historia ya zamani"
" kuwa ujumbe 1 wa system; hifadhi N za mwisho bila kuchakatwa; chaguo-"
"msingi=20)"

#: src/uagent/util_tools.py:1852
msgid "List long-term memory notes"
msgstr "Orodhesha madokezo ya kumbukumbu ya muda mrefu"

#: src/uagent/util_tools.py:1854
msgid "Delete a long-term memory note by index (see :mem-list)"
msgstr "Futa dokezo la kumbukumbu ya muda mrefu kwa index (angalia :mem-list)"

#: src/uagent/util_tools.py:1856
msgid "Copy file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Nakili faili au saraka (inaunga mkono -f/--overwrite na -p/--mkdirs)"

#: src/uagent/util_tools.py:1858
msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Hamisha faili au saraka (inaunga mkono -f/--overwrite na -p/--mkdirs)"

#: src/uagent/util_tools.py:1860
msgid "Show the first n lines of a file (default=20)"
msgstr "Onyesha mistari n ya kwanza ya faili (chaguo msingi=20)"

#: src/uagent/util_tools.py:1861
msgid "Show the last n lines of a file (default=20)"
msgstr "Onyesha mistari n ya mwisho ya faili (chaguo msingi=20)"

#: src/uagent/util_tools.py:1863
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr "Futa faili/saraka kwa onyesho la awali + uthibitisho"

#: src/uagent/util_tools.py:1865
msgid ""
"List shared long-term memory notes (requires UAGENT_SHARED_MEMORY_FILE)"
msgstr ""
"Orodhesha madokezo ya kumbukumbu ya muda mrefu ya pamoja (inahitaji "
"UAGENT_SHARED_MEMORY_FILE)"

#: src/uagent/util_tools.py:1867
msgid "Delete a shared long-term memory note by index"
msgstr "Futa dokezo la kumbukumbu ya muda mrefu ya pamoja kwa index"

#: src/uagent/util_tools.py:1869
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Weka hali ya hoja (0=zimwa, 1=chini, 2=wastani, 3=juu; auto/minimal/xhigh)"

#: src/uagent/util_tools.py:1871
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Weka hali ya urefu wa maelezo (0=zimwa, 1=chini, 2=wastani, 3=juu; bila "
"hoja=endelea)"

