msgid "List directory entries (e.g. :ls / :ls .. / :ls ~ / :ls C:\\path)"
msgstr "Orodhesha maingizo ya saraka (mf. :ls / :ls .. / :ls ~ / :ls C:\\path)"

#: src/uagent/util_tools.py:1832
msgid "List loaded tools"
msgstr "Orodhesha zana zilizopakiwa"

#: src/uagent/util_tools.py:1834
