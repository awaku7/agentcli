#: src/uagent/util_tools.py:194
msgid ""
"Specify working directory. If not set, uses UAGENT_WORKDIR env var or the "
"current directory."
msgstr ""
"Bainisha saraka ya kazi. Ikiwa haijawekwa, hutumia kigezo cha mazingira "
"UAGENT_WORKDIR au saraka ya sasa."

#: src/uagent/util_tools.py:201
msgid ""
"Non-interactive mode. Do not start the stdin loop; exit after processing the"
" startup file (if any)."
msgstr ""
"Hali isiyoingiliana. Usianzishe mzunguko wa stdin; toka baada ya kuchakata "
"faili ya kuanzisha (kama ipo)."

#: src/uagent/util_tools.py:650
msgid ""
"[Skill execution]\n"
"This skill is intended to be run. Read the skill body carefully and follow the instructions.\n"
"If the skill contains tasks, continue until they are complete.\n"
"Use tools as needed.\n"
msgstr ""
"[Utekelezaji wa ujuzi]\n"
"Ujuzi huu umekusudiwa kuendeshwa. Soma maudhui ya ujuzi kwa makini na fuata maagizo.\n"
"Ikiwa ujuzi una kazi, endelea hadi zikamilike.\n"
"Tumia zana inapohitajika.\n"

#: src/uagent/util_tools.py:657
msgid "When finished, always call `finish_skill` if available.\n"
msgstr "Unapomaliza, kila mara piga `finish_skill` ikiwa ipo.\n"

#: src/uagent/util_tools.py:793
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"Chagua namba ya ujuzi wa kuendesha. Weka c ili kughairi.\n"
"Kidokezo: :skills clear  (ondoa ujuzi uliotumika)\n"
"Weka namba:"

#: src/uagent/util_tools.py:829
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Endesha ujuzi huu kama maagizo ya kiwango cha mfumo na uendelee kuwa hai katika kipindi hiki?\n"
"\n"
"Jina: %(name)s\n"
"Njia: %(path)s\n"
"\n"
"Endelea? Weka y ili kuendesha, au c ili kughairi."

#: src/uagent/util_tools.py:937
#, python-format
msgid ""
":clean will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
":clean itafuta faili za logi za mazungumzo (scheck_log_*.jsonl) kutoka diski.\n"
"Saraka ya logi: %(dir)s\n"
"Kanuni: jumla ya ujumbe wa mtumiaji/msaidizi/zana bila mfumo <= %(threshold)d\n"
"Lengo: %(n)d\n"
"\n"
"Endelea? Weka y ili kuendesha, au c ili kughairi."

#: src/uagent/util_tools.py:1181
#, python-brace-format
msgid ""
"Delete {count} path(s)?\n"
"\n"
"{paths}\n"
"\n"
"Enter y to proceed, or c to cancel."
msgstr ""
"Futa njia {count}?\n"
"\n"
"{paths}\n"
"\n"
"Weka y ili kuendelea, au c ili kughairi."

