#: src/uagent/util_tools.py:2070
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"Futa logi za mazungumzo (scheck_log_*.jsonl) ambapo idadi ya ujumbe wa "
"mtumiaji/msaidizi/zana (bila system) ni <= N (chaguo-msingi=10)"

#: src/uagent/util_tools.py:2074
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"Punguza historia ya mazungumzo (hifadhi ujumbe wa mwisho N usio wa system; "
"chaguo-msingi=40)"

#: src/uagent/util_tools.py:2078
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
