#: src/uagent/core.py:1224
msgid "- Summarize the conversation chunk in English.\n"
msgstr "- Fanya muhtasari wa sehemu hii ya mazungumzo kwa Kiingereza.\n"

#: src/uagent/core.py:1226
msgid ""
"- Keep the summary concise but include key decisions, constraints, and "
"pending items.\n"
msgstr ""
"- Weka muhtasari uwe mfupi lakini ujumuishe maamuzi muhimu, vizuizi, na "
"mambo yanayosubiri.\n"

#: src/uagent/core.py:1228
msgid "- Output should be directly usable as a system message."
msgstr "- Matokeo yanapaswa kutumika moja kwa moja kama ujumbe wa mfumo."

#: src/uagent/core.py:1231
msgid "Conversation chunk:\n"
msgstr "Sehemu ya mazungumzo:\n"

#: src/uagent/core.py:1233
msgid "Write a concise summary of this chunk."
msgstr "Andika muhtasari mfupi wa sehemu hii."

#: src/uagent/core.py:1237
msgid "- You are updating an existing conversation summary.\n"
msgstr "- Unasasisha muhtasari uliopo wa mazungumzo.\n"

#: src/uagent/core.py:1238
msgid "- Preserve important facts from the previous summary.\n"
msgstr "- Hifadhi ukweli muhimu kutoka kwenye muhtasari uliopita.\n"

#: src/uagent/core.py:1240
msgid ""
"- Merge in the new chunk without losing constraints, decisions, or pending "
"items.\n"
msgstr ""
"- Unganisha sehemu mpya bila kupoteza vizuizi, maamuzi, au mambo "
"yanayosubiri.\n"

#: src/uagent/core.py:1242
msgid "- Keep the result concise and suitable for a system message."
msgstr "- Weka matokeo yawe mafupi na yafae kama ujumbe wa mfumo."

#: src/uagent/core.py:1245
msgid "Previous summary:\n"
msgstr "Muhtasari uliopita:\n"

#: src/uagent/core.py:1247
msgid "New chunk:\n"
msgstr "Sehemu mpya:\n"

#: src/uagent/core.py:1249
msgid "Update the summary while keeping the prior context intact."
msgstr "Sasisha muhtasari huku ukihifadhi muktadha wa awali bila kubadilika."

#: src/uagent/core.py:1268
msgid "Summary of the conversation so far:\n"
msgstr "Muhtasari wa mazungumzo hadi sasa:\n"

#: src/uagent/core.py:1275
#, python-brace-format
msgid ""
"[INFO] shrink_llm: {old_n} -> {new_n} messages (compressed {old_part_n} "
"older messages into 1 summary; kept {tail_n} tail)"
msgstr ""
"[INFO] shrink_llm: {old_n} -> {new_n} ujumbe (imebana {old_part_n} ujumbe wa"
" zamani kuwa muhtasari 1; imehifadhi {tail_n} wa mwisho)"

