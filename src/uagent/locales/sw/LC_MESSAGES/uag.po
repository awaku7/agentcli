#: src/uagent/welcome.py:64
msgid "[Quick Guide]"
msgstr "[Mwongozo wa Haraka]"

#: src/uagent/welcome.py:65
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- Chat: andika ujumbe na utume (GUI: Ctrl+Enter pia inapatikana)."

#: src/uagent/welcome.py:67
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Mistari mingi: weka mstari wenye tu 'f' ili kuingia hali ya mistari mingi "
"(malizia kwa \"\"\"end)."

#: src/uagent/welcome.py:70
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.). Note: commands start with ':' (colon) instead of '/' "
"(slash)."
msgstr ""
"- Amri: andika ':help' ili kuona amri za mfumo (usimamizi wa kumbukumbu, "
"ukandamizaji wa historia, nk.). Kumbuka: amri huanza na ':' (koloni) badala "
"ya '/' (mkwaju)."

#: src/uagent/welcome.py:72
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Toka: ':exit' au ':quit' humaliza kipindi."

#: src/uagent/welcome.py:74
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Picha: GUI inaunga mkono buruta na dondosha; kwenye CUI unaweza kuingiza "
"njia ya faili kwa uchanganuzi wa picha."

#: src/uagent/welcome.py:77
#, python-format
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs: `%(docs_cmd)s` huonyesha nyaraka zilizojumuishwa; "
"`%(webinspect_cmd)s` huonyesha msaada wa Web Inspector (`--path/--open` pia "
"zinapatikana)."

#: src/uagent/welcome.py:81
msgid "[Examples]"
msgstr "[Mifano]"

#: src/uagent/welcome.py:82
msgid "- \"Analyze the source code in this folder and create a README.md.\""
msgstr "- \"Chambua msimbo chanzo kwenye folda hii na unda README.md.\""

#: src/uagent/welcome.py:84
msgid ""
"- \"Take a screenshot of the current desktop and describe the visible window"
" contents.\""
msgstr ""
"- \"Piga picha ya skrini ya eneo-kazi la sasa na eleza yaliyomo ya dirisha "
"linaloonekana.\""

#: src/uagent/welcome.py:86
msgid "- \"Create a monthly summary report from this Excel file.\""
msgstr ""
"- \"Tengeneza ripoti ya muhtasari wa kila mwezi kutoka kwenye faili hii ya "
"Excel.\""

#: src/uagent/welcome.py:87
msgid "- \"Read this PDF and list three key points.\""
msgstr "- \"Soma PDF hii na orodhesha pointi tatu kuu.\""

#: src/uagent/welcome.py:88
msgid "- \"Search the latest news and summarize a specific topic.\""
msgstr "- \"Tafuta habari za hivi karibuni na fupisha mada maalum.\""

#: src/uagent/welcome.py:193
msgid "-- More -- (Enter: next) "
msgstr "-- Zaidi -- (Enter: inayofuata) "

