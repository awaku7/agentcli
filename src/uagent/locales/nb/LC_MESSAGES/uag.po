msgstr ""
"- Slå sammen den nye delen uten å miste begrensninger, beslutninger eller "
"utestående elementer.\n"

#: src/uagent/core.py:1397
msgid "- Keep the result concise and suitable for a system message."
msgstr "- Hold resultatet kortfattet og egnet for en systemmelding."

#: src/uagent/core.py:1400
