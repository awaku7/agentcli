msgstr "- Du oppdaterer en eksisterende samtaleoppsummering.\n"

#: src/uagent/core.py:1533
msgid "- Preserve important facts from the previous summary.\n"
msgstr "- Bevar viktige fakta fra den forrige oppsummeringen.\n"

#: src/uagent/core.py:1535
msgid ""
"- Merge in the new chunk without losing constraints, decisions, or pending "
"items.\n"
msgstr ""
"- Slå sammen den nye delen uten å miste begrensninger, beslutninger eller "
"utestående elementer.\n"

#: src/uagent/core.py:1537
