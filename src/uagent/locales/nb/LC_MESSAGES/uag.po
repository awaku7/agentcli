#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[Hurtigguide]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr ""
"- Chat: skriv en melding og send (GUI: Ctrl+Enter er også tilgjengelig)."

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Flerradig: skriv en linje som bare er 'f' for å gå inn i flerradig modus "
"(avslutt med \"\"\"end)."

#: src/uagent/welcome.py:68
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.)."
msgstr ""
"- Kommandoer: skriv ':help' for å se systemkommandoer (loggadministrasjon, "
"historikkkomprimering osv.)."

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Avslutt: ':exit' eller ':quit' avslutter økten."

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Bilder: GUI støtter dra og slipp; i CUI kan du skrive inn en filsti for "
"bildeanalyse."

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs: `%(docs_cmd)s` viser medfølgende dokumenter; `%(webinspect_cmd)s` "
"viser hjelpen for Web Inspector (`--path/--open` også tilgjengelig)."

