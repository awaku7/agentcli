#: src/uagent/util_tools.py:194
msgid ""
"Specify working directory. If not set, uses UAGENT_WORKDIR env var or the "
"current directory."
msgstr ""
"Määritä työhakemisto. Jos sitä ei aseteta, käytetään UAGENT_WORKDIR-"
"ympäristömuuttujaa tai nykyistä hakemistoa."

#: src/uagent/util_tools.py:201
msgid ""
"Non-interactive mode. Do not start the stdin loop; exit after processing the"
" startup file (if any)."
msgstr ""
"Ei-interaktiivinen tila. Älä käynnistä stdin-silmukkaa; poistu "
"käynnistystiedoston käsittelyn jälkeen (jos sellainen on)."

#: src/uagent/util_tools.py:650
msgid ""
"[Skill execution]\n"
"This skill is intended to be run. Read the skill body carefully and follow the instructions.\n"
"If the skill contains tasks, continue until they are complete.\n"
"Use tools as needed.\n"
msgstr ""
"[Taidon suoritus]\n"
"Tämä taito on tarkoitettu suoritettavaksi. Lue taidon teksti huolellisesti ja noudata ohjeita.\n"
"Jos taito sisältää tehtäviä, jatka, kunnes ne on suoritettu.\n"
"Käytä työkaluja tarpeen mukaan.\n"

#: src/uagent/util_tools.py:657
msgid "When finished, always call `finish_skill` if available.\n"
msgstr "Kun olet valmis, kutsu aina `finish_skill`, jos se on käytettävissä.\n"

#: src/uagent/util_tools.py:793
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"Valitse suoritettava taidon numero. Peruuta kirjoittamalla c.\n"
"Vinkki: :skills clear (poista käytetyt taidot)\n"
"Anna numero:"

#: src/uagent/util_tools.py:829
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Suoritetaanko tämä taito järjestelmätason ohjeena ja pidetäänkö se aktiivisena tässä istunnossa?\n"
"\n"
"Nimi: %(name)s\n"
"Polku: %(path)s\n"
"\n"
"Jatketaanko? Kirjoita y suorittaaksesi tai c peruuttaaksesi."

#: src/uagent/util_tools.py:937
#, python-format
msgid ""
":clean will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
":clean poistaa keskustelulokitiedostot (scheck_log_*.jsonl) levyltä.\n"
"Lokihakemisto: %(dir)s\n"
"Sääntö: käyttäjä-/avustaja-/työkaluviestien kokonaismäärä ilman järjestelmäviestejä <= %(threshold)d\n"
"Kohteet: %(n)d\n"
"\n"
"Jatketaanko? Kirjoita y suorittaaksesi tai c peruuttaaksesi."

#: src/uagent/util_tools.py:1181
#, python-brace-format
msgid ""
"Delete {count} path(s)?\n"
"\n"
"{paths}\n"
"\n"
"Enter y to proceed, or c to cancel."
msgstr ""
"Poistetaanko {count} polku(a)?\n"
"\n"
"{paths}\n"
"\n"
"Kirjoita y jatkaaksesi tai c peruuttaaksesi."

