#: src/uagent/util_tools.py:205
msgid ""
"Specify working directory. If not set, uses UAGENT_WORKDIR env var or the "
"current directory."
msgstr ""
"Especifique o diretório de trabalho. Se não for definido, usa a variável de "
"ambiente UAGENT_WORKDIR ou o diretório atual."

#: src/uagent/util_tools.py:212
msgid ""
"Non-interactive mode. Do not start the stdin loop; exit after processing the"
" startup file (if any)."
msgstr ""
"Modo não interativo. Não inicie o loop de stdin; saia após processar o "
"arquivo de inicialização (se houver)."

#: src/uagent/util_tools.py:661
msgid ""
"[Skill execution]\n"
"This skill is intended to be run. Read the skill body carefully and follow the instructions.\n"
"If the skill contains tasks, continue until they are complete.\n"
"Use tools as needed.\n"
msgstr ""
"[Execução da habilidade]\n"
"Esta habilidade foi feita para ser executada. Leia o corpo da habilidade com atenção e siga as instruções.\n"
"Se a habilidade contiver tarefas, continue até concluí-las.\n"
"Use ferramentas conforme necessário.\n"

#: src/uagent/util_tools.py:668
msgid "When finished, always call `finish_skill` if available.\n"
msgstr "Ao terminar, sempre chame `finish_skill` se estiver disponível.\n"

#: src/uagent/util_tools.py:806
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"Selecione um número de skill para executar. Digite c para cancelar.\n"
"Dica: :skills clear  (remove as skills aplicadas)\n"
"Digite o número:"

#: src/uagent/util_tools.py:842
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Executar esta skill como uma instrução de nível de sistema e mantê-la ativa nesta sessão?\n"
"\n"
"Nome: %(name)s\n"
"Caminho: %(path)s\n"
"\n"
"Prosseguir? Digite y para executar ou c para cancelar."

#: src/uagent/util_tools.py:950
#, python-format
msgid ""
":clean will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
":clean apagará os arquivos de registro de conversa (scheck_log_*.jsonl) do disco.\n"
"Diretório dos logs: %(dir)s\n"
"Regra: total de mensagens de usuário/assistente/ferramenta, excluindo system, <= %(threshold)d\n"
"Alvos: %(n)d\n"
"\n"
"Prosseguir? Digite y para executar ou c para cancelar."

#: src/uagent/util_tools.py:1194
#, python-brace-format
msgid ""
"Delete {count} path(s)?\n"
"\n"
"{paths}\n"
"\n"
"Enter y to proceed, or c to cancel."
msgstr ""
"Deseja excluir {count} caminho(s)?\n"
"\n"
"{paths}\n"
"\n"
"Digite y para continuar ou c para cancelar."

