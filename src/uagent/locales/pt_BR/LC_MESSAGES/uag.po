#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[Guia rápido]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr ""
"- Chat: digite uma mensagem e envie (na GUI, Ctrl+Enter também está "
"disponível)."

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Multiline: digite uma linha que seja apenas 'f' para entrar no modo "
"multilinha (termine com uma linha contendo \"\"\"end)."

#: src/uagent/welcome.py:68
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.)."
msgstr ""
"- Comandos: digite ':help' para ver os comandos do sistema (gerenciamento de"
" logs, compressão do histórico etc.)."

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Saída: ':exit' ou ':quit' encerra a sessão."

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Imagens: a GUI suporta arrastar e soltar; no CUI você pode informar o "
"caminho de um arquivo para análise de imagem."

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs: `%(docs_cmd)s` mostra os documentos incluídos; `%(webinspect_cmd)s` "
"mostra a ajuda do Web Inspector (`--path/--open` também disponível)."

#: src/uagent/welcome.py:79
msgid "[Examples]"
msgstr "[Exemplos]"

