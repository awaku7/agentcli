#: src/uagent/runtime/runtime_env.py:186
msgid ""
"[INFO] .env.sec content does not match the current startup UAGENT_* "
"environment variables. [y] Update .env.sec with current values / [s] Use "
".env.sec values (apply to session) / [N] Skip: "
msgstr ""
"[INFO] Der Inhalt von .env.sec stimmt nicht mit den aktuellen "
"UAGENT_*-Umgebungsvariablen überein. [y] .env.sec mit aktuellen Werten "
"aktualisieren / [s] .env.sec-Werte verwenden (auf Sitzung anwenden) / [N] "
"Überspringen:"

#: src/uagent/runtime/runtime_env.py:203
msgid "[INFO] Applied .env.sec values to the current session."
msgstr ""
"[INFO] Die Werte aus .env.sec wurden auf die aktuelle Sitzung angewendet."

#: src/uagent/runtime/runtime_env.py:212
msgid ""
"[INFO] .env.sec content does not match the current startup UAGENT_* "
"environment variables. Use `uag_envsec` to update it."
msgstr ""
"[INFO] Der Inhalt von .env.sec stimmt nicht mit den "
"UAGENT_*‑Umgebungsvariablen des aktuellen Starts überein. Verwenden Sie "
"`uag_envsec`, um sie zu aktualisieren."

#: src/uagent/runtime/runtime_env.py:224
#, python-format
msgid "Updated .env.sec: %(path)s"
msgstr ".env.sec wurde aktualisiert: %(path)s"

#: src/uagent/runtime/runtime_env.py:228
#, python-format
msgid "[WARN] Failed to update .env.sec: %(err)s"
msgstr "[WARN] Aktualisierung von .env.sec fehlgeschlagen: %(err)s"

#: src/uagent/runtime/runtime_env.py:238
msgid ""
"[INFO] .env.sec is missing. Create it from the current startup UAGENT_* "
"environment variables? [y/N] "
msgstr ""
"[INFO] .env.sec fehlt. Aus den UAGENT_*‑Umgebungsvariablen des aktuellen "
"Starts erstellen? [j/N] "

#: src/uagent/runtime/runtime_env.py:254
msgid ""
"[INFO] .env.sec is missing. Use `uag_envsec` to create it from the current "
"startup UAGENT_* environment variables."
msgstr ""
"[INFO] .env.sec fehlt. Verwenden Sie `uag_envsec`, um sie aus den "
"UAGENT_*‑Umgebungsvariablen des aktuellen Starts zu erstellen."

