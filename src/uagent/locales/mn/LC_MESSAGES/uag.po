msgstr ""
"Урт хугацааны санах ойн тэмдэглэлийг индексээр нь устгах (:mem-list-ийг үзнэ"
" үү)"

msgid "Copy file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Файл эсвэл лавлах хуулах (-f/--overwrite болон -p/--mkdirs-г дэмждэг)"

msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Файл эсвэл лавлахыг зөөх (-f/--overwrite болон -p/--mkdirs-г дэмждэг)"

