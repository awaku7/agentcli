msgstr "Устгах хэрэглэгчийн профайл файл олдсонгүй."

#: src/uagent/util_tools.py:1908
msgid "Copy file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Файл эсвэл лавлах хуулах (-f/--overwrite болон -p/--mkdirs-г дэмждэг)"

#: src/uagent/util_tools.py:1910
msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Файл эсвэл лавлахыг зөөх (-f/--overwrite болон -p/--mkdirs-г дэмждэг)"

#: src/uagent/util_tools.py:1912
msgid "Show the first n lines of a file (default=20)"
msgstr "Файлын эхний n мөрийг харуулах (өгөгдмөл = 20)"

#: src/uagent/util_tools.py:1913
msgid "Show the last n lines of a file (default=20)"
msgstr "Файлын сүүлийн n мөрийг харуулах (өгөгдмөл = 20)"

#: src/uagent/util_tools.py:1915
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr ""
"Урьдчилан харах + баталгаажуулах боломжтой файл(ууд)/директоруудыг устгана "
"уу"

#: src/uagent/util_tools.py:1917
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Үндэслэл тогтоох горимыг тохируулах (0=унтраах, 1=бага, 2=дунд, 3=өндөр; "
"автомат/хамгийн бага/х өндөр)"

#: src/uagent/util_tools.py:1919
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Товч мэдээлэл өгөх горимыг тохируулах (0=унтраах, 1=бага, 2=дунд, 3=өндөр; "
"arg байхгүй=хадгалах)"

#: src/uagent/util_tools.py:1920
msgid "Exit"
msgstr "Гарах"

#: src/uagent/util_tools.py:1923
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr ""
"- Олон мөрт оруулах горимд орохын тулд зөвхөн 'f' гэсэн мөрийг оруулна уу."

#: src/uagent/util_tools.py:1925
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"- Олон мөрт оруулах горимыг дуусгахын тулд яг %(sentinel)s мөрийг оруулна "
"уу."

#: src/uagent/util_tools.py:2125
msgid "Exiting."
msgstr "Гарч байна."

#: src/uagent/util_tools.py:2128
msgid "Unknown command: :%(cmd)s"
msgstr "Үл мэдэгдэх тушаал: %(cmd)s"

#: src/uagent/util_tools.py:2279
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"Доор жагсаасан гол цэгүүд нь энэ хэрэглэгчийн урт хугацааны санах ой "
"(байнгын санамж) -аас авсан хэсэг юм. Тэдгээрийг хэрэглэгчийн талаарх суурь "
"мэдээлэл болгон ашигла. Гэсэн хэдий ч харилцан ярианд шинээр өгсөн "
"мэдээллийг үргэлж эрэмбэлэх бөгөөд хэрэв энэ нь хуучин мэдээлэлтэй зөрчилдөж"
" байвал хамгийн сүүлийн үеийн мэдээллийг аваарай."

#: src/uagent/web.py:532
msgid ""
"[WARN] Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"[АНХААРУУЛГА] Энэ өрөөнд өөр ажил аль хэдийн ажиллаж байна. Үүнийг дуусгасны"
" дараа дахин оролдоно уу."

#: src/uagent/web.py:624 src/uagent/web.py:744
msgid ""
"[FATAL] Environment variable UAGENT_PROVIDER is not set.\n"
"Please check environment variables when starting the web server."
msgstr ""
"[FATAL] UAGENT_PROVIDER орчны хувьсагчийг тохируулаагүй байна.\n"
"Вэб серверийг эхлүүлэхдээ орчны хувьсагчдыг шалгана уу."

#: src/uagent/web.py:694
msgid "[INFO] Loaded long-term memory."
msgstr "[МЭДЭЭЛЭЛ] Урт хугацааны санах ойг ачаалсан."

#: src/uagent/web.py:706
msgid "[INFO] Loaded shared long-term memory."
msgstr "[МЭДЭЭЛЭЛ] Хуваалцсан урт хугацааны санах ойг ачааллаа."

#: src/uagent/web.py:741
msgid ""
"[FATAL] Web worker error.\n"
"%(err)s"
msgstr ""
"[FATAL] Вэб ажилчдын алдаа.\n"
"%(err)s"

