msgstr ""
"Хэрэгслийн жанрын бит "
"маск(1=үндсэн,2=comm,4=office,8=devel,16=iot,32=exec,64=external,128=media,256=file,512=index,1023=all).Заасан"
" үед интерактив жанрын сануулгыг алгасдаг."

#: src/uagent/util_tools.py:238 src/uagent/web.py:1276
