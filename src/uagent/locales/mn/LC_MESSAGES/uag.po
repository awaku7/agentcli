#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[Түргэн гарын авлага]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- Чат: мессеж бичээд илгээх (GUI: Ctrl+Enter бас боломжтой)."

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Олон мөр: олон мөрийн горимд орохын тулд зөвхөн 'f' гэсэн мөрийг оруулна "
"уу (\"\"\" төгсгөлөөр төгсдөг)."

msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.). Note: commands start with ':' (colon) instead of '/' "
"(slash)."
msgstr "- Командууд: системийн командуудыг (бүртгэлийн удирдлага, түүхийг шахах гэх мэт) үзэхийн тулд ':help' гэж бичнэ үү. Тэмдэглэл: командууд '/' (налуу зураас) биш ':' (цэг) тэмдэгтээр эхэлнэ."

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Exit: ':exit' эсвэл ':quit' нь сессийг дуусгана."

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Зураг: GUI чирэх & буулгах дэмждэг; CUI дээр та зургийн шинжилгээнд "
"зориулж файлын замыг оруулах боломжтой."

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Докс: `%(docs_cmd)s` нь багцалсан баримтуудыг харуулдаг; "
"`%(webinspect_cmd)s` нь вэб байцаагчийн тусламжийг харуулдаг "
"(`--path/--open` бас боломжтой)."

#: src/uagent/welcome.py:79
msgid "[Examples]"
msgstr "[Жишээ нь]"

#: src/uagent/welcome.py:80
msgid "- \"Analyze the source code in this folder and create a README.md.\""
msgstr "- \"Энэ хавтсанд байгаа эх кодыг шинжлээд README.md үүсгэнэ үү.\""

#: src/uagent/welcome.py:82
msgid ""
"- \"Take a screenshot of the current desktop and describe the visible window"
" contents.\""
msgstr ""
"- \"Одоогийн ширээний дэлгэцийн агшинг авч, харагдах цонхны агуулгыг "
"тайлбарлана уу.\""

#: src/uagent/welcome.py:84
msgid "- \"Create a monthly summary report from this Excel file.\""
msgstr "- \"Энэ Excel файлаас сарын хураангуй тайланг үүсгэ.\""

#: src/uagent/welcome.py:85
msgid "- \"Read this PDF and list three key points.\""
msgstr "- \"Энэ PDF-г уншаад гурван гол зүйлийг жагсаа.\""

#: src/uagent/welcome.py:86
msgid "- \"Search the latest news and summarize a specific topic.\""
msgstr "- \"Сүүлийн үеийн мэдээ хайж, тодорхой сэдвийг нэгтгэн дүгнэ.\""

