#: src/uagent/profile_manager.py:208 src/uagent/profile_manager.py:309
#, python-brace-format
msgid ""
"You are a user profiling agent. Analyze the conversation log and extract "
"the user's:\n"
"1. Environment (OS, shell, editor, etc.)\n"
"2. Preferences (coding style, preferred tools, verbosity preference, "
"etc.)\n"
"3. Constraints (security rules, offline requirements, etc.)\n"
