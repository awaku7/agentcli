#: src/uagent/runtime/runtime_env.py:186
msgid ""
"[INFO] .env.sec content does not match the current startup UAGENT_* "
"environment variables. [y] Update .env.sec with current values / [s] Use "
".env.sec values (apply to session) / [N] Skip: "
msgstr ""
"[INFO] .env.sec файлын агуулга одоогийн UAGENT_* орчны хувьсагчтай "
"тохирохгүй байна. [y] .env.sec-ийг одоогийн утгаар шинэчлэх / [s] .env.sec "
"утгыг ашиглах (сессид хэрэглэх) / [N] Алгасах:"

