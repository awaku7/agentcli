msgid "User profile cleared successfully."
msgstr "Gebruikersprofiel succesvol gewist."

#: src/uagent/util_tools.py:1804
msgid "No user profile file found to clear."
msgstr "Geen gebruikersprofielbestand gevonden om te wissen."

#: src/uagent/util_tools.py:1868
msgid "Show this help"
msgstr "Deze hulp tonen"

#: src/uagent/util_tools.py:1869
msgid "Restart input from the beginning"
msgstr "Invoer vanaf het begin opnieuw starten"

#: src/uagent/util_tools.py:1870
msgid "Show log file list"
msgstr "Logbestandenlijst tonen"

#: src/uagent/util_tools.py:1873
msgid ""
"Change workdir without confirmation (e.g. :cd .. / :cd ~ / :cd C:\\path / "
":cd /)"
msgstr ""
"Werkmap wijzigen zonder bevestiging (bijv. :cd .. / :cd ~ / :cd C:\\path / "
":cd /)"

#: src/uagent/util_tools.py:1876
msgid "List directory entries (e.g. :ls / :ls .. / :ls ~ / :ls C:\\path)"
msgstr "Mapinhoud weergeven (bijv. :ls / :ls .. / :ls ~ / :ls C:\\path)"

#: src/uagent/util_tools.py:1877
msgid "List loaded tools"
msgstr "Geladen tools tonen"

#: src/uagent/util_tools.py:1880
msgid "Manage UAGENT_* env vars and save .env.sec"
msgstr "Beheer UAGENT_* omgevingsvariabelen en sla .env.sec op"

#: src/uagent/util_tools.py:1882
msgid "Manage/apply skills (e.g. :skills / :skills active / :skills clear)"
msgstr ""
"Skills beheren/toepassen (bijv. :skills / :skills active / :skills clear)"

#: src/uagent/util_tools.py:1884
msgid "Load a past log (overwrites current conversation history)"
msgstr "Een eerder log laden (overschrijft de huidige gespreksgeschiedenis)"

#: src/uagent/util_tools.py:1886
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Let op: na het uitvoeren wordt om bevestiging "
"gevraagd; als u 'y' kiest, wordt het geladen log vooraan toegevoegd aan het "
"huidige sessielogbestand (overschrijven, geen back-up)."

#: src/uagent/util_tools.py:1890
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"Gesprekslogbestanden verwijderen (scheck_log_*.jsonl) wanneer het aantal "
"user-/assistant-/tool-berichten (zonder system) <= N is (standaard=10)"

#: src/uagent/util_tools.py:1894
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"Gespreksgeschiedenis inkorten (laatste N niet-systemberichten behouden; "
"standaard=40)"

#: src/uagent/util_tools.py:1898
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"Geschiedenis inkorten via LLM-samenvatting (oudere geschiedenis samenvatten "
"tot 1 systeembericht; laatste N onbewerkte berichten behouden; standaard=20)"

#: src/uagent/util_tools.py:1900
msgid "List long-term memory notes"
msgstr "Langetermijngeheugen-notities weergeven"

#: src/uagent/util_tools.py:1902
msgid "Delete a long-term memory note by index (see :mem-list)"
msgstr "Een langetermijngeheugen-notitie verwijderen op index (zie :mem-list)"

#: src/uagent/util_tools.py:1903
#, fuzzy
msgid "Show the learned user profile, or generate it from past logs"
msgstr ""
"Toon het geleerde gebruikersprofiel (omgeving, voorkeuren, beperkingen)"

#: src/uagent/util_tools.py:1904
#, fuzzy
msgid "Generate user profile from past logs"
msgstr "Geen gebruikersprofielgegevens gevonden."

#: src/uagent/util_tools.py:1905
msgid "Clear the learned user profile data"
msgstr "Wis de geleerde gebruikersprofielgegevens"

#: src/uagent/util_tools.py:1907
msgid "Copy file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr "Bestand of map kopiëren (ondersteunt -f/--overwrite en -p/--mkdirs)"

#: src/uagent/util_tools.py:1909
msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr ""
"Bestand of map verplaatsen (ondersteunt -f/--overwrite en -p/--mkdirs)"

#: src/uagent/util_tools.py:1911
msgid "Show the first n lines of a file (default=20)"
msgstr "Toon de eerste n regels van een bestand (standaard=20)"

#: src/uagent/util_tools.py:1912
msgid "Show the last n lines of a file (default=20)"
msgstr "Toon de laatste n regels van een bestand (standaard=20)"

#: src/uagent/util_tools.py:1914
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr "Bestand(en)/map(pen) verwijderen met voorbeeldweergave + bevestiging"

#: src/uagent/util_tools.py:1916
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Redeneermodus instellen (0=uit, 1=laag, 2=middel, 3=hoog; "
"auto/minimal/xhigh)"

#: src/uagent/util_tools.py:1918
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Uitvoerigheidsmodus instellen (0=uit, 1=laag, 2=middel, 3=hoog; geen "
"arg=behouden)"

#: src/uagent/util_tools.py:1919
msgid "Exit"
msgstr "Afsluiten"

#: src/uagent/util_tools.py:1922
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr ""
"- Voer een regel in die alleen 'f' bevat om de modus voor invoer over "
"meerdere regels te openen."

#: src/uagent/util_tools.py:1924
#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"  - Om de modus voor meerregelige invoer te beëindigen, voert u een regel in"
" die exact %(sentinel)s is."

#: src/uagent/util_tools.py:2129
msgid "Exiting."
msgstr "Afsluiten."

#: src/uagent/util_tools.py:2132
#, python-format
msgid "Unknown command: :%(cmd)s"
msgstr "Onbekend commando: :%(cmd)s"

#: src/uagent/util_tools.py:2283
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"De onderstaande opsommingstekens zijn uittreksels uit het "
"langetermijngeheugen van deze gebruiker (persistente memo's). Gebruik ze als"
" achtergrondinformatie over de gebruiker. Geef echter altijd prioriteit aan "
"nieuw verstrekte informatie in het gesprek en als het in tegenspraak is met "
"oudere informatie, neem dan de nieuwste informatie over."

#: src/uagent/web.py:534
msgid ""
"[WARN] Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"[WARN] Er draait al een andere taak in deze ruimte. Probeer het opnieuw "
"nadat die is voltooid."

#: src/uagent/web.py:626 src/uagent/web.py:746
msgid ""
"[FATAL] Environment variable UAGENT_PROVIDER is not set.\n"
"Please check environment variables when starting the web server."
msgstr ""
"[FATAL] Omgevingsvariabele UAGENT_PROVIDER is niet ingesteld.\n"
"Controleer de omgevingsvariabelen bij het starten van de webserver."

#: src/uagent/web.py:696
