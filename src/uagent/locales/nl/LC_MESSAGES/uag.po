msgstr ""
"- Voeg het nieuwe segment samen zonder beperkingen, beslissingen of "
"openstaande punten te verliezen.\n"

#: src/uagent/core.py:1397
msgid "- Keep the result concise and suitable for a system message."
msgstr "- Houd het resultaat beknopt en geschikt voor een systeembericht."

#: src/uagent/core.py:1400
