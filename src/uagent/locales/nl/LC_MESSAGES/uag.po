msgstr "Schrijf een beknopte samenvatting van dit segment."

#: src/uagent/core.py:1392
msgid "- You are updating an existing conversation summary.\n"
msgstr "- U bent een bestaande gesprekssamenvatting aan het bijwerken.\n"

#: src/uagent/core.py:1393
