#: src/uagent/welcome.py:64
msgid "[Quick Guide]"
msgstr "  Korte handleiding"

#: src/uagent/welcome.py:65
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr ""
"- Chat: typ een bericht en verstuur (GUI: Ctrl+Enter is ook beschikbaar)."

#: src/uagent/welcome.py:67
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Multiline: voer een regel in die net 'f' is om naar de multiline-modus te "
"gaan (eindig met \"\"\"einde)."

#: src/uagent/welcome.py:70
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.). Note: commands start with ':' (colon) instead of '/' "
"(slash)."
msgstr ""
"- Commando's: typ ':help' om systeemcommando's te zien (logboekbeheer, "
"geschiedeniscompressie, enz.). Opmerking: commando's beginnen met een "
"dubbele punt ':' in plaats von een schuine streep '/'."

#: src/uagent/welcome.py:72
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Afsluiten: ':exit' of ':quit' beëindigt de sessie."

#: src/uagent/welcome.py:74
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Afbeeldingen: GUI ondersteunt slepen en neerzetten; in CUI kunt u een "
"bestandspad invoeren voor beeldanalyse."

#: src/uagent/welcome.py:77
#, python-format
msgid ""
"- Docs: `%(docs_cmd)s` shows bundled docs; `%(webinspect_cmd)s` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs: `%(docs_cmd)s` toont de meegeleverde documenten; "
"`%(webinspect_cmd)s` toont de Web Inspector-hulp (`--path/--open` ook "
"beschikbaar)."

#: src/uagent/welcome.py:81
msgid "[Examples]"
msgstr "Voorbeelden"

#: src/uagent/welcome.py:82
msgid "- \"Analyze the source code in this folder and create a README.md.\""
msgstr "- \"Analyseer de broncode in deze map en maak een README.md.\""

#: src/uagent/welcome.py:84
msgid ""
"- \"Take a screenshot of the current desktop and describe the visible window"
" contents.\""
msgstr ""
"- \"Maak een screenshot van het huidige bureaublad en beschrijf de zichtbare"
" inhoud van het venster.\""

#: src/uagent/welcome.py:86
msgid "- \"Create a monthly summary report from this Excel file.\""
msgstr "- \"Maak een maandelijks overzichtsrapport van dit Excel-bestand.\""

#: src/uagent/welcome.py:87
msgid "- \"Read this PDF and list three key points.\""
msgstr "- \"Lees deze PDF en noem drie belangrijke punten.\""

#: src/uagent/welcome.py:88
msgid "- \"Search the latest news and summarize a specific topic.\""
msgstr "- \"Zoek in het laatste nieuws en vat een specifiek onderwerp samen.\""

