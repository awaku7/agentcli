#: src/uagent/core.py:1523
msgid "- Output should be directly usable as a system message."
msgstr "- يجب أن يكون الناتج قابلاً للاستخدام مباشرة كرسالة نظام."

#: src/uagent/core.py:1526
msgid "Conversation chunk:\n"
msgstr "جزء المحادثة:\n"

#: src/uagent/core.py:1528
msgid "Write a concise summary of this chunk."
msgstr "اكتب ملخصاً موجزاً لهذا الجزء."

#: src/uagent/core.py:1532
msgid "- You are updating an existing conversation summary.\n"
msgstr "- أنت تقوم بتحديث ملخص محادثة موجود بالفعل.\n"

#: src/uagent/core.py:1533
msgid "- Preserve important facts from the previous summary.\n"
msgstr "- حافظ على الحقائق المهمة من الملخص السابق.\n"

#: src/uagent/core.py:1535
msgid ""
"- Merge in the new chunk without losing constraints, decisions, or pending "
"items.\n"
msgstr "- ادمج الجزء الجديد دون فقدان القيود أو القرارات أو البنود المعلقة.\n"

#: src/uagent/core.py:1537
msgid "- Keep the result concise and suitable for a system message."
msgstr "- حافظ على إيجاز النتيجة ومناسبتها لرسالة النظام."

#: src/uagent/core.py:1540
msgid "Previous summary:\n"
msgstr "الملخص السابق:\n"

#: src/uagent/core.py:1542
msgid "New chunk:\n"
msgstr "الجزء الجديد:\n"

#: src/uagent/core.py:1544
msgid "Update the summary while keeping the prior context intact."
msgstr "قم بتحديث الملخص مع الحفاظ على السياق السابق سليماً."

msgid "[shrink_llm] Summarizing chunk %(i)d/%(n)d..."
