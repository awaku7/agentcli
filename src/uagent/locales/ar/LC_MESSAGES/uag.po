msgstr "- لخص جزء المحادثة باللغة الإنجليزية.\n"

#: src/uagent/core.py:1521
msgid ""
"- Keep the summary concise but include key decisions, constraints, and "
"pending items.\n"
msgstr ""
"- حافظ على إيجاز الملخص مع تضمين القرارات الرئيسية والقيود والبنود "
