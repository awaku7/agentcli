#: src/uagent/util_tools.py:1511
msgid "Load a past log (overwrites current conversation history)"
msgstr "تحميل سجل سابق (للكتابة فوق سجل المحادثة الحالي)"

#: src/uagent/util_tools.py:1513
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"ملحوظة: بعد التشغيل، سيُطلب منك التأكيد؛ يؤدي اختيار \"y\" إلى إضافة السجل "
"الذي تم تحميله إلى ملف سجل الجلسة الحالي (الكتابة فوقه، بدون نسخ احتياطي)."

#: src/uagent/util_tools.py:1517
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"حذف سجلات المحادثات (scheck_log_*.jsonl) حيث يكون عدد رسائل "
"المستخدم/المساعد/الأداة (باستثناء النظام) <= N (افتراضي=10)"

#: src/uagent/util_tools.py:1521
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"تقليص سجل المحادثات (احتفظ بآخر عدد من الرسائل غير التابعة للنظام؛ الافتراضي"
" = 40)"

#: src/uagent/util_tools.py:1525
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"تقليص التاريخ عبر تلخيص LLM (تلخيص التاريخ القديم في رسالة نظام واحدة؛ "
"الاحتفاظ بآخر N خام؛ الافتراضي = 20)"

