#: src/uagent/profile_manager.py:623
msgid ""
"You are a user profiling agent. Analyze the conversation log and extract the user's:\n"
"1. Environment (OS, shell, editor, etc.)\n"
"2. Preferences (coding style, preferred tools, verbosity preference, etc.)\n"
"3. Constraints (security rules, offline requirements, etc.)\n"
"\n"
"Do NOT include temporary questions, chit-chat, or sensitive credentials.\n"
"You MUST respond ONLY with a valid JSON object matching this schema:\n"
"{\n"
"  \"environment\": {\"os\": \"string\", \"shell\": \"string\", \"editor\": \"string\"},\n"
"  \"preferences\": [\"string\"],\n"
"  \"constraints\": [\"string\"]\n"
"}"
msgstr ""
"أنت وكيلُ إعدادِ ملفٍّ شخصيّ للمستخدم. حلّل سجلّ المحادثة واستخرج ما يلي:\n"
"1. البيئة (نظام التشغيل، الصدفة، المحرر، إلخ)\n"
"2. التفضيلات (أسلوب البرمجة، الأدوات المفضلة، تفضيل مستوى الإطالة، إلخ)\n"
"3. القيود (قواعد الأمان، متطلبات العمل دون اتصال، إلخ)\n"
"\n"
"لا تُضمّن الأسئلة المؤقتة أو الحديث العابر أو بيانات الاعتماد الحساسة.\n"
"يجب أن تردّ فقط بكائن JSON صالح يطابق هذا المخطط:\n"
"{\n"
"  \"environment\": {\"os\": \"string\", \"shell\": \"string\", \"editor\": \"string\"},\n"
"  \"preferences\": [\"string\"],\n"
"  \"constraints\": [\"string\"]\n"
"}"

#: src/uagent/profile_manager.py:738
msgid "Failed to initialize LLM client."
msgstr "فشل تهيئة عميل LLM."

#: src/uagent/profile_manager.py:743
#, python-format
msgid "Found %(total_files)d log files. Starting incremental profiling..."
msgstr "تم العثور على %(total_files)d ملف سجل. جارٍ بدء التحليل التدريجي..."

msgid ""
"You are a user profiling agent. Analyze the conversation log and extract:\n"
"1. Environment (OS, shell, editor) — only if clearly evident from the log.\n"
"2. Preferences — specific, actionable traits observed from the user's actual requests and corrections:\n"
"   - Response style: concise or verbose? Code-heavy or prose-heavy? Bullet points or paragraphs?\n"
"   - Language: prefers Japanese, English, or mixed?\n"
"   - Tool usage: which tools/commands does the user frequently reach for?\n"
"   - Quality standard: tolerates quick workarounds or insists on proper solutions?\n"
"   - Confirmation: wants explicit approval before file operations, or prefers to skip prompts?\n"
"   - Any other recurring pattern in how the user gives instructions.\n"
"3. Constraints — explicit rules the user stated (e.g. 'must be offline', 'no external APIs', 'keep it simple', 'no extra dependencies').\n"
"\n"
"Do NOT infer preferences from a single request; only extract patterns that appear repeatedly.\n"
"Do NOT include temporary questions, chit-chat, or sensitive credentials.\n"
"You MUST respond ONLY with a valid JSON object matching this schema:\n"
"{\n"
"  \"environment\": {\"os\": \"string\", \"shell\": \"string\", \"editor\": \"string\"},\n"
"  \"preferences\": [\"string\"],\n"
"  \"constraints\": [\"string\"]\n"
"}"
msgstr ""
"أنت وكيل ملفات تعريف المستخدم. تحليل سجل المحادثة واستخراج:"
"1."
"البيئة (نظام التشغيل، الصدفة، المحرر) - ​​فقط إذا كان واضحًا من السجل."
"2."
"التفضيلات - سمات محددة وقابلة للتنفيذ تمت ملاحظتها من طلبات المستخدم"
"الفعلية وتصحيحاته:"
"-"
"نمط الاستجابة: موجز أم مطول؟ كود ثقيل أم نثر ثقيل؟ نقاط أو فقرات؟"
"-"
"اللغة: هل تفضل اليابانية أم الإنجليزية أم المختلطة؟"
"-"
"استخدام الأداة: ما هي الأدوات/الأوامر التي يلجأ إليها المستخدم بشكل"
"متكرر؟"
"-"
"معيار الجودة: هل تقبل الحلول السريعة أم تصر على الحلول المناسبة؟"
"-"
"التأكيد: هل تريد الحصول على موافقة صريحة قبل عمليات الملف، أو تفضل"
"تخطي المطالبات؟"
"-"
"أي نمط متكرر آخر في كيفية قيام المستخدم بإعطاء التعليمات."
"3."
"القيود - القواعد الصريحة التي ذكرها المستخدم (على سبيل المثال، \"يجب"
"أن تكون غير متصل بالإنترنت\"، \"لا توجد واجهات برمجة تطبيقات خارجية\"،"
"\"اجعل الأمر بسيطًا\"، \"لا توجد تبعيات إضافية\")."
"لا تستنتج التفضيلات من طلب واحد؛ فقط قم باستخراج الأنماط التي تظهر"
"بشكل متكرر."
"لا"
"تقم بتضمين أسئلة مؤقتة أو دردشة أو بيانات اعتماد حساسة."
"يجب"
"عليك الرد فقط باستخدام كائن JSON صالح يطابق هذا المخطط:"
"{"
"\\\"environment\\\":"
"{\\\"os\\\": \\\"string\\\"، \\\"shell\\\": \\\"string\\\"،"
"\\\"editor\\\": \\\"string\\\"}،"
"\\\"preferences\\\":"
"[\\\"string\\\"]،"
"\\\"constraints\\\":"
"[\\\"سلسلة\\\"]"
"}"

