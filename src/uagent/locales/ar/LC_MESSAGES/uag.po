msgstr ""
"[WARN] وصلت عملية ضغط السجل إلى حد السياق حتى عند chunk_size=1؛ جارٍ الرجوع "
"إلى shrink_messages()."

#: src/uagent/core.py:1618
msgid ""
"[WARN] history compression could not reduce chunk_size further; falling back"
" to shrink_messages()."
msgstr ""
"[WARN] تعذّر تقليل chunk_size أكثر؛ جارٍ الرجوع إلى shrink_messages()."

#: src/uagent/core.py:1626
#, python-format
msgid ""
"[WARN] history compression context length exceeded; retrying with "
