#: src/uagent/util_tools.py:973
msgid ""
"[Skill execution]\n"
"This skill is intended to be run. Read the skill body carefully and follow the instructions.\n"
"If the skill contains tasks, continue until they are complete.\n"
"Use tools as needed.\n"
msgstr ""
"[कौशल्य अंमलबजावणी]\n"
"हे कौशल्य चालवायचे आहे. स्किल बॉडी काळजीपूर्वक वाचा आणि सूचनांचे अनुसरण करा.\n"
"कौशल्यामध्ये कार्ये असल्यास, ती पूर्ण होईपर्यंत सुरू ठेवा.\n"
"आवश्यकतेनुसार साधने वापरा."

#: src/uagent/util_tools.py:980
msgid "When finished, always call `finish_skill` if available.\n"
msgstr "पूर्ण झाल्यावर, उपलब्ध असल्यास नेहमी `finish_skill` वर कॉल करा."

#: src/uagent/util_tools.py:1132
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"चालविण्यासाठी कौशल्य क्रमांक निवडा. रद्द करण्यासाठी c प्रविष्ट करा.\n"
"टीप: : कौशल्ये स्पष्ट (लागू कौशल्ये काढून टाका)\n"
"क्रमांक प्रविष्ट करा:"

#: src/uagent/util_tools.py:1168
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"हे कौशल्य प्रणाली-स्तरीय सूचना म्हणून चालवायचे आणि ते या सत्रात सक्रिय ठेवायचे?\n"
"\n"
"नाव: %(name)s\n"
"मार्ग: %(path)s\n"
"\n"
"पुढे जायचे? चालवण्यासाठी y प्रविष्ट करा किंवा रद्द करण्यासाठी c प्रविष्ट करा."

#: src/uagent/util_tools.py:1230
#, python-format
msgid ""
"[clean] Invalid argument: %(arg)r (specify number=threshold; default is "
"%(default)d)"
msgstr ""
"[स्वच्छ] अवैध युक्तिवाद: %(arg)r (क्रमांक=थ्रेशोल्ड निर्दिष्ट करा; डीफॉल्ट "
"%(default)d आहे)"

#: src/uagent/util_tools.py:1279
#, python-format
msgid ""
"will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"डिस्कवरून संभाषण लॉग फाइल्स (scheck_log_*.jsonl) हटवेल.\n"
"लॉग dir: %(dir)s\n"
"नियम: सिस्टम वगळून एकूण वापरकर्ता/सहाय्यक/साधन संदेश <= %(threshold)d\n"
"लक्ष्य: %(n)d\n"
"\n"
"पुढे जायचे? चालवण्यासाठी y प्रविष्ट करा किंवा रद्द करण्यासाठी c प्रविष्ट करा."

#: src/uagent/util_tools.py:1347
#, python-format
msgid " - (%(count)d msgs) %(path)s"
msgstr "- (%(count)d संदेश) %(path)s"

#: src/uagent/util_tools.py:1391
#, python-format
msgid ""
"will overwrite the current session log file and prepend the loaded log (no backup).\n"
"\n"
"Current log: %(cur_log)s\n"
"Source log: %(src_log)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
