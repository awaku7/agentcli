msgstr "[माहिती] दीर्घकालीन मेमरी लोड केली."

#: src/uagent/web.py:710
msgid "[INFO] Loaded shared long-term memory."
msgstr "[माहिती] सामायिक केलेली दीर्घकालीन मेमरी लोड केली."

