msgstr "पुष्टीशिवाय वर्कडायर बदला (उदा. :cd .. / :cd ~ / :cd C:\\path / :cd /)"

#: src/uagent/util_tools.py:1880
msgid "List directory entries (e.g. :ls / :ls .. / :ls ~ / :ls C:\\path)"
msgstr "निर्देशिका नोंदींची यादी करा (उदा. :ls / :ls .. / :ls ~ / :ls C:\\path)"

#: src/uagent/util_tools.py:1881
msgid "List loaded tools"
msgstr "लोड केलेल्या साधनांची यादी करा"

#: src/uagent/util_tools.py:1884
msgid "Manage UAGENT_* env vars and save .env.sec"
msgstr "UAGENT_* पर्यावरण चल व्यवस्थापित करा आणि .env.sec जतन करा"

#: src/uagent/util_tools.py:1886
msgid "Manage/apply skills (e.g. :skills / :skills active / :skills clear)"
msgstr ""
"कौशल्ये व्यवस्थापित करा/लागू करा (उदा. : कौशल्य / : कौशल्य सक्रिय / : कौशल्य"
" स्पष्ट)"

#: src/uagent/util_tools.py:1888
msgid "Load a past log (overwrites current conversation history)"
msgstr "मागील लॉग लोड करा (वर्तमान संभाषण इतिहास अधिलिखित करते)"

#: src/uagent/util_tools.py:1890
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"टीप: धावल्यानंतर, तुम्हाला पुष्टीकरणासाठी विचारले जाईल; 'y' निवडणे वर्तमान "
"सत्र लॉग फाइलमध्ये लोड केलेले लॉग प्रीपेंड करते (ओव्हरराइट, बॅकअप नाही)."

#: src/uagent/util_tools.py:1894
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"संभाषण लॉग हटवा (scheck_log_*.jsonl) जेथे वापरकर्ता/सहाय्यक/टूल संदेशांची "
"संख्या (सिस्टम वगळून) आहे <= N (डीफॉल्ट=10)"

#: src/uagent/util_tools.py:1898
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"संभाषण इतिहास संकुचित करा (शेवटचे N नॉन-सिस्टम संदेश ठेवा; डीफॉल्ट=40)"

#: src/uagent/util_tools.py:1902
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"LLM सारांशाद्वारे इतिहास संकुचित करा (1 सिस्टम संदेशामध्ये जुना इतिहास "
"सारांशित करा; शेवटचा N रॉ ठेवा; डीफॉल्ट=20)"

#: src/uagent/util_tools.py:1904
msgid "List long-term memory notes"
msgstr "दीर्घकालीन मेमरी नोट्स सूचीबद्ध करा"

#: src/uagent/util_tools.py:1906
msgid "Delete a long-term memory note by index (see :mem-list)"
msgstr "निर्देशांकानुसार दीर्घकालीन मेमरी नोट हटवा (पहा :mem-सूची)"

#: src/uagent/util_tools.py:1908
msgid "Copy file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr ""
"फाइल किंवा निर्देशिका कॉपी करा (-f/--ओव्हरराईट आणि -p/--mkdirs चे समर्थन "
"करते)"

#: src/uagent/util_tools.py:1910
msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr ""
"फाइल किंवा निर्देशिका हलवा (-f/--ओव्हरराईट आणि -p/--mkdirs ला समर्थन देते)"

#: src/uagent/util_tools.py:1912
msgid "Show the first n lines of a file (default=20)"
msgstr "फाइलच्या पहिल्या n ओळी दाखवा (डिफॉल्ट=20)"

#: src/uagent/util_tools.py:1913
msgid "Show the last n lines of a file (default=20)"
msgstr "फाईलच्या शेवटच्या n ओळी दाखवा (डिफॉल्ट=20)"

#: src/uagent/util_tools.py:1915
msgid "Delete file(s)/directory(ies) with preview + confirm"
msgstr "पूर्वावलोकन + पुष्टीसह फाइल/डिरेक्टरी(ies) हटवा"

#: src/uagent/util_tools.py:1917
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr "तर्क मोड सेट करा (0=बंद, 1=कमी, 2=मध्यम, 3=उच्च; स्वयं/किमान/xउच्च)"

#: src/uagent/util_tools.py:1919
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr "वर्बोसिटी मोड सेट करा (0=बंद, 1=कमी, 2=मध्यम, 3=उच्च; अर्ग=कीप नाही)"

#: src/uagent/util_tools.py:1920
msgid "Exit"
msgstr "बाहेर पडा"

#: src/uagent/util_tools.py:1923
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr ""
"- मल्टीलाइन इनपुट मोडमध्ये प्रवेश करण्यासाठी फक्त 'f' असलेली ओळ एंटर करा."

#: src/uagent/util_tools.py:1925
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"- मल्टीलाइन इनपुट मोड समाप्त करण्यासाठी, अचूक %(sentinel)s असलेली ओळ "
"प्रविष्ट करा."

#: src/uagent/util_tools.py:2125
msgid "Exiting."
msgstr "बाहेर पडत आहे."

#: src/uagent/util_tools.py:2128
msgid "Unknown command: :%(cmd)s"
msgstr "अज्ञात आदेश: :%(cmd)s"

#: src/uagent/util_tools.py:2279
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"खाली सूचीबद्ध केलेले बुलेट पॉइंट्स या वापरकर्त्याच्या दीर्घकालीन मेमरी "
"(परसिस्टंट मेमो) चे उतारे आहेत. वापरकर्त्याबद्दल पार्श्वभूमी माहिती म्हणून "
"त्यांचा वापर करा. तथापि, संभाषणात नेहमी नवीन प्रदान केलेल्या माहितीला "
"प्राधान्य द्या आणि जर ती जुन्या माहितीच्या विरोधात असेल तर नवीनतम माहितीचा "
"अवलंब करा."

#: src/uagent/web.py:532
msgid ""
"[WARN] Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"[चेतावणी] या खोलीत दुसरे कार्य आधीच चालू आहे. कृपया ते पूर्ण झाल्यानंतर "
"पुन्हा प्रयत्न करा."

