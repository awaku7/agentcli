msgid "When finished, always call `finish_skill` if available.\n"
msgstr "Cuando termine, llame siempre a `finish_skill` si está disponible.\n"

#: src/uagent/util_tools.py:802
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"Seleccione un número de skill para ejecutar. Introduzca c para cancelar.\n"
"Consejo: :skills clear  (eliminar los skills aplicados)\n"
"Introduzca un número:"

#: src/uagent/util_tools.py:838
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"¿Ejecutar esta skill como instrucción a nivel de sistema y mantenerla activa en esta sesión?\n"
"\n"
"Nombre: %(name)s\n"
"Ruta: %(path)s\n"
"\n"
"¿Continuar? Escriba y para ejecutar, o c para cancelar."

#: src/uagent/util_tools.py:944
#, python-format
msgid ""
":clean will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
":clean eliminará los archivos de registro de conversación (scheck_log_*.jsonl) del disco.\n"
"Directorio de registros: %(dir)s\n"
"Regla: total de mensajes de usuario/asistente/herramienta excluyendo system <= %(threshold)d\n"
"Objetivos: %(n)d\n"
"\n"
"¿Continuar? Escriba y para ejecutar, o c para cancelar."

#: src/uagent/util_tools.py:1188
#, python-brace-format
msgid ""
"Delete {count} path(s)?\n"
"\n"
"{paths}\n"
"\n"
"Enter y to proceed, or c to cancel."
msgstr ""
"¿Eliminar {count} ruta(s)?\n"
"\n"
"{paths}\n"
"\n"
"Introduzca y para continuar o c para cancelar."

#: src/uagent/util_tools.py:1328
