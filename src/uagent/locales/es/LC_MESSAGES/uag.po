msgstr "logs: mostrando %(shown)d/%(total)d (dir=%(dir)s)"

#: src/uagent/core.py:557
msgid "Log files:"
msgstr "Archivos de registro:"

#: src/uagent/core.py:957
msgid ""
"- Summarize the conversation log so far in English.\n"
"- Keep the summary concise but include key decisions, constraints, and pending items.\n"
"- Output should be directly usable as a system message titled 'Summary of the conversation so far'.\n"
msgstr ""
"- Resuma el registro de la conversación hasta ahora en inglés.\n"
"- Mantenga el resumen conciso, pero incluya decisiones clave, restricciones y elementos pendientes.\n"
"- La salida debe poder usarse directamente como un mensaje de sistema titulado 'Summary of the conversation so far'.\n"

#: src/uagent/core.py:991
#, python-format
msgid "Error while calling LLM for history compression: %(err)r"
msgstr "Error al llamar al LLM para comprimir el historial: %(err)r"

#: src/uagent/core.py:1009
msgid "Summary of the conversation so far:\n"
msgstr "Resumen de la conversación hasta ahora:\n"

#: src/uagent/core.py:1017
#, python-brace-format
msgid ""
"[INFO] Conversation history was summarized by the LLM: old_part={old_n} -> 1"
" summary + tail_part={tail_n}"
msgstr ""
"[INFO] El historial de la conversación fue resumido por el LLM: "
"old_part={old_n} -> 1 summary + tail_part={tail_n}"

#: src/uagent/core.py:1032
msgid "Available commands:"
msgstr "Available comandos:"

#: src/uagent/core.py:1033
msgid "  :help                 Show this help"
msgstr "  :help                 Mostrar esta ayuda"

#: src/uagent/core.py:1034
msgid "  (in multiline input) \"\"\"retry  Restart input from the beginning"
msgstr ""
"  (en entrada multilínea) \"\"\"retry  Reiniciar la entrada desde el "
"principio"

#: src/uagent/core.py:1035
msgid "  :logs / :list         Show log file list"
msgstr "  :logs / :list         Mostrar la lista de archivos de registro"

#: src/uagent/core.py:1037
msgid ""
"  :cd <path>            Change workdir without confirmation (e.g. :cd .. / "
":cd ~ / :cd C:\\path / :cd /)"
msgstr ""
"  :cd <path>            Change directorio de trabajo without confirmation "
"(e.g. :cd .. / :cd ~ / :cd C:\\path / :cd /)"

#: src/uagent/core.py:1040
msgid ""
"  :ls [path]            List directory entries (e.g. :ls / :ls .. / :ls ~ / "
":ls C:\\path)"
msgstr ""
"  :ls [path]            Listar entradas del directorio (p. ej., :ls / :ls .."
" / :ls ~ / :ls C:\\path)"

#: src/uagent/core.py:1043
msgid ""
"  :load <idx|path>      Load a past log (overwrites current conversation "
"history)"
msgstr ""
"  :load <idx|path>      Cargar un registro anterior (sobrescribe el "
"historial actual)"

#: src/uagent/core.py:1046
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"                       Nota: después de ejecutarlo, se le pedirá "
"confirmación; si elige 'y', el registro cargado se antepondrá al archivo de "
"registro de la sesión actual (sobrescritura, sin copia de seguridad)."

#: src/uagent/core.py:1049
msgid ""
"  :clean [N]            Delete conversation logs (scheck_log_*.jsonl) where "
"the count of user/assistant/tool messages (excluding system) is <= N "
"(default=10)"
msgstr ""
"  :clean [N]            Eliminar registros de conversación "
"(scheck_log_*.jsonl) cuyo recuento de mensajes de "
"usuario/asistente/herramienta (excluyendo system) sea <= N "
"(predeterminado=10)"

#: src/uagent/core.py:1052
msgid ""
"  :shrink [N]           Shrink conversation history (keep last N non-system "
"messages; default=40)"
msgstr ""
"  :shrink [N]           Reducir el historial de conversación (conservar los "
"últimos N mensajes no system; predeterminado=40)"

#: src/uagent/core.py:1055
msgid ""
"  :shrink_llm [N]       Shrink history via LLM summarization (summarize "
"older history into 1 system message; keep last N raw; default=20)"
msgstr ""
"  :shrink_llm [N]       Reducir el historial mediante resumen del LLM "
"(resumir el historial antiguo en 1 mensaje system; conservar los últimos N "
"sin procesar; predeterminado=20)"

#: src/uagent/core.py:1057
msgid "  :mem-list             List long-term memory notes"
msgstr "  :mem-list             Listar notas de memoria a largo plazo"

#: src/uagent/core.py:1059
msgid ""
"  :mem-del <index>      Delete a long-term memory note by index (see :mem-"
"list)"
msgstr ""
"  :mem-del <index>      Eliminar una nota de memoria a largo plazo por "
"índice (ver :mem-list)"

#: src/uagent/core.py:1062
msgid ""
"  :shared-mem-list      List shared long-term memory notes (requires "
"UAGENT_SHARED_MEMORY_FILE)"
msgstr ""
"  :shared-mem-list      Listar notas de memoria compartida a largo plazo "
"(requiere UAGENT_SHARED_MEMORY_FILE)"

#: src/uagent/core.py:1064
msgid "  :shared-mem-del <i>   Delete a shared long-term memory note by index"
msgstr ""
"  :shared-mem-del <i>   Eliminar una nota de memoria compartida por índice"

#: src/uagent/core.py:1066
msgid ""
"  :r [0|1|2|3|auto|minimal|xhigh]  Set reasoning mode (0=off, 1=low, "
"2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"  :r [0|1|2|3|auto|minimal|xhigh]  Establecer el modo de razonamiento "
"(0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"

#: src/uagent/core.py:1069
msgid ""
"  :v [0|1|2|3]          Set verbosity mode (0=off, 1=low, 2=medium, 3=high; "
"no arg=cycle)"
msgstr ""
"  :v [0|1|2|3]          Establecer el modo de verbosidad (0=off, 1=low, "
"2=medium, 3=high; sin argumento=ciclo)"

#: src/uagent/core.py:1071
msgid "  :exit / :quit         Exit"
msgstr "  :exit / :quit         Salir"

#: src/uagent/core.py:1073
msgid "Hints:"
msgstr "Sugerencias:"

#: src/uagent/core.py:1074
msgid "  - Enter a line that is just 'f' to enter multiline input mode."
msgstr ""
"  - Introduzca una línea que sea solo 'f' para entrar en modo de entrada "
"multilínea."

#: src/uagent/core.py:1075
#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"  - Para terminar el modo multilínea, introduzca una línea que sea "
"exactamente %(sentinel)s."

