#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1511
msgid "Load a past log (overwrites current conversation history)"
msgstr ""
"Cargar un registro anterior (sobrescribe el historial de conversaciones "
"actual)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1513
msgid ""
"                       Note: after running, you will be asked for "
"confirmation; choosing 'y' prepends the loaded log into the current session "
"log file (overwrite, no backup)."
msgstr ""
"Nota: después de ejecutar, se le pedirá confirmación; al elegir 'y' se "
"antepone el registro cargado al archivo de registro de la sesión actual "
"(sobrescritura, sin copia de seguridad)."

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1517
msgid ""
"Delete conversation logs (scheck_log_*.jsonl) where the count of "
"user/assistant/tool messages (excluding system) is <= N (default=10)"
msgstr ""
"Eliminar registros de conversación (scheck_log_*.jsonl) donde el recuento de"
" mensajes de usuario/asistente/herramienta (excluyendo el sistema) es <= N "
"(predeterminado=10)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1521
msgid ""
"Shrink conversation history (keep last N non-system messages; default=40)"
msgstr ""
"Reducir el historial de conversaciones (conservar los últimos N mensajes que"
" no pertenecen al sistema; valor predeterminado = 40)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1525
msgid ""
"Shrink history via LLM summarization (summarize older history into 1 system "
"message; keep last N raw; default=20)"
msgstr ""
"Reducir el historial mediante el resumen LLM (resumir el historial anterior "
"en 1 mensaje del sistema; mantener los últimos N sin procesar; valor "
"predeterminado = 20)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1527
msgid "List long-term memory notes"
msgstr "Enumerar notas de memoria a largo plazo"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1529
msgid "Delete a long-term memory note by index (see :mem-list)"
msgstr "Eliminar una nota de memoria a largo plazo por índice (ver :mem-list)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1531
