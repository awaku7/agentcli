#: src/uagent/util_tools.py:1416 src/uagent/util_tools.py:1449
msgid ""
"Shared long-term memory is not enabled (UAGENT_SHARED_MEMORY_FILE is not "
"set)."
msgstr ""
"La memoria compartida a largo plazo no está habilitada "
"(UAGENT_SHARED_MEMORY_FILE no está definido)."

#: src/uagent/util_tools.py:1798
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"Los puntos enumerados a continuación son extractos de la memoria a largo plazo de este usuario (memos persistentes). Úselos como información de contexto sobre el usuario. Sin embargo, dé prioridad siempre a la información proporcionada más recientemente en la conversación y, si contradice a la anterior, adopte la información más reciente.\n"
"\n"

#: src/uagent/web.py:457
msgid ""
"Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"Ya hay otra tarea en ejecución en esta sala. Inténtelo de nuevo cuando "
"termine."

#: src/uagent/web.py:536 src/uagent/web.py:655
msgid ""
"Environment variable UAGENT_PROVIDER is not set.\n"
"Please check environment variables when starting the web server."
msgstr ""
"La variable de entorno UAGENT_PROVIDER no está definida.\n"
"Revise las variables de entorno al iniciar el servidor web."

