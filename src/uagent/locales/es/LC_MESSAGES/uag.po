"Listar notas de memoria a largo plazo compartidas (requiere "
"UAGENT_SHARED_MEMORY_FILE)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1535
msgid "Delete a shared long-term memory note by index"
msgstr "Eliminar una nota de memoria compartida a largo plazo por índice"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1537
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Establecer el modo de razonamiento (0=apagado, 1=bajo, 2=medio, 3=alto; "
"automático/mínimo/xalto)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1539
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Establecer el modo de detalle (0=desactivado, 1=bajo, 2=medio, 3=alto; sin "
"arg=mantener)"

