#, python-format
msgid ""
"  - To end multiline input mode, enter a line that is exactly %(sentinel)s."
msgstr ""
"  - Untuk mengakhiri mode input multibaris, masukkan baris yang tepat "
"%(sentinel)s."

#: src/uagent/util_tools.py:2125
