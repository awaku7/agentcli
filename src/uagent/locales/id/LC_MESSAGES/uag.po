#: src/uagent/welcome.py:62
msgid "[Quick Guide]"
msgstr "[Panduan Singkat]"

#: src/uagent/welcome.py:63
msgid "- Chat: type a message and send (GUI: Ctrl+Enter is also available)."
msgstr "- Chat: ketik pesan dan kirim (GUI: Ctrl+Enter juga tersedia)."

#: src/uagent/welcome.py:65
msgid ""
"- Multiline: enter a line that is just 'f' to enter multiline mode (end with"
" \"\"\"end)."
msgstr ""
"- Multiline: masukkan baris yang hanya berisi 'f' untuk masuk mode multiline"
" (akhiri dengan \"\"\"end)."

#: src/uagent/welcome.py:68
msgid ""
"- Commands: type ':help' to see system commands (log management, history "
"compression, etc.)."
msgstr ""
"- Commands: ketik ':help' untuk melihat perintah sistem (pengelolaan log, "
"kompresi riwayat, dll.)."

#: src/uagent/welcome.py:70
msgid "- Exit: ':exit' or ':quit' ends the session."
msgstr "- Keluar: ':exit' atau ':quit' mengakhiri sesi."

#: src/uagent/welcome.py:72
msgid ""
"- Images: GUI supports drag & drop; in CUI you can input a file path for "
"image analysis."
msgstr ""
"- Gambar: GUI mendukung seret dan lepas; di CUI Anda dapat memasukkan path "
"file untuk analisis gambar."

#: src/uagent/welcome.py:75
msgid ""
"- Docs: `uag docs` shows bundled docs; `uag docs webinspect` shows Web "
"Inspector help (`--path/--open` also available)."
msgstr ""
"- Docs: `uag docs` menampilkan dokumen bawaan; `uag docs webinspect` "
"menampilkan bantuan Web Inspector (`--path/--open` juga tersedia)."

#: src/uagent/welcome.py:78
