msgstr "Hapus file/direktori dengan pratinjau + konfirmasi"

#: src/uagent/util_tools.py:1917
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Setel mode penalaran (0=nonaktif, 1=rendah, 2=sedang, 3=tinggi; "
"auto/minimal/xhigh)"

#: src/uagent/util_tools.py:1919
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Setel mode verbositas (0=nonaktif, 1=rendah, 2=sedang, 3=tinggi; tanpa "
"argumen=pertahankan)"

#: src/uagent/util_tools.py:1920
