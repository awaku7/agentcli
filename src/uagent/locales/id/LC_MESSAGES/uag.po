msgid "Move file or directory (supports -f/--overwrite and -p/--mkdirs)"
msgstr ""
"Pindahkan file atau direktori (mendukung -f/--overwrite dan -p/--mkdirs)"

#: src/uagent/util_tools.py:1912
msgid "Show the first n lines of a file (default=20)"
msgstr "Tampilkan n baris pertama dari file (default=20)"

#: src/uagent/util_tools.py:1913
msgid "Show the last n lines of a file (default=20)"
msgstr "Tampilkan n baris terakhir dari file (default=20)"

#: src/uagent/util_tools.py:1915
