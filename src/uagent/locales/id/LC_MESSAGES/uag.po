#: src/uagent/core.py:1214
msgid "- Summarize the conversation chunk in English.\n"
msgstr "- Ringkas potongan percakapan ini dalam bahasa Inggris.\n"

#: src/uagent/core.py:1216
msgid ""
"- Keep the summary concise but include key decisions, constraints, and "
"pending items.\n"
msgstr ""
"- Buat ringkasan tetap singkat, tetapi sertakan keputusan penting, batasan, "
"dan item yang masih tertunda.\n"

#: src/uagent/core.py:1218
msgid "- Output should be directly usable as a system message."
msgstr "- Keluaran harus langsung dapat digunakan sebagai pesan sistem."

#: src/uagent/core.py:1221
msgid "Conversation chunk:\n"
msgstr "Potongan percakapan:\n"

#: src/uagent/core.py:1223
msgid "Write a concise summary of this chunk."
msgstr "Tulis ringkasan singkat untuk potongan ini."

#: src/uagent/core.py:1227
msgid "- You are updating an existing conversation summary.\n"
msgstr "- Anda sedang memperbarui ringkasan percakapan yang sudah ada.\n"

#: src/uagent/core.py:1228
msgid "- Preserve important facts from the previous summary.\n"
msgstr "- Pertahankan fakta penting dari ringkasan sebelumnya.\n"

#: src/uagent/core.py:1229
msgid ""
"- Merge in the new chunk without losing constraints, decisions, or pending "
"items.\n"
msgstr ""
"- Gabungkan potongan baru tanpa kehilangan batasan, keputusan, atau item "
"yang tertunda.\n"

#: src/uagent/core.py:1230
msgid "- Keep the result concise and suitable for a system message."
msgstr "- Jaga hasil tetap singkat dan sesuai untuk pesan sistem."

#: src/uagent/core.py:1233
msgid "Previous summary:\n"
msgstr "Ringkasan sebelumnya:\n"

#: src/uagent/core.py:1235
msgid "New chunk:\n"
msgstr "Potongan baru:\n"

#: src/uagent/core.py:1237
msgid "Update the summary while keeping the prior context intact."
msgstr "Perbarui ringkasan sambil mempertahankan konteks sebelumnya."

#: src/uagent/core.py:1256
msgid "Summary of the conversation so far:\n"
msgstr "Ringkasan percakapan sejauh ini:\n"

#: src/uagent/core.py:1263
msgid ""
"[INFO] shrink_llm: {old_n} -> {new_n} messages (compressed {old_part_n} "
"older messages into 1 summary; kept {tail_n} tail)"
msgstr ""
"[INFO] shrink_llm: {old_n} -> {new_n} pesan (mengompresi {old_part_n} pesan "
"lama menjadi 1 ringkasan; menyimpan {tail_n} pesan terakhir)"

