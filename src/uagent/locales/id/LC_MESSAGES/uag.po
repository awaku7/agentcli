msgstr "Bagian baru:\n"

#: src/uagent/core.py:1404
msgid "Update the summary while keeping the prior context intact."
msgstr "Perbarui ringkasan sambil menjaga konteks sebelumnya tetap utuh."

#: src/uagent/core.py:1425
