#: C:\KAIHATSU\agentcli\src\uagent\checks.py:19
msgid ""
"Please install Git. Example: sudo apt install git (Ubuntu/Debian) or sudo "
"yum install git (CentOS/RHEL)"
msgstr ""
"Installa Git. Esempio: sudo apt install git (Ubuntu/Debian) oppure sudo yum "
"install git (CentOS/RHEL)"

#: C:\KAIHATSU\agentcli\src\uagent\checks.py:22
msgid ""
"Please install Git. If using Homebrew: brew install git, or install Xcode "
"Command Line Tools: xcode-select --install"
msgstr ""
"Installa Git. Se usi Homebrew: brew install git, oppure installa gli Xcode "
"Command Line Tools: xcode-select --install"

