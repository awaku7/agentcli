#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1549
msgid ""
"Set reasoning mode (0=off, 1=low, 2=medium, 3=high; auto/minimal/xhigh)"
msgstr ""
"Imposta la modalità di ragionamento (0=off, 1=basso, 2=medio, 3=alto; "
"auto/minimal/xhigh)"

#: C:/KAIHATSU/agentcli/src/uagent/util_tools.py:1551
msgid "Set verbosity mode (0=off, 1=low, 2=medium, 3=high; no arg=keep)"
msgstr ""
"Imposta la modalità di verbosità (0=off, 1=basso, 2=medio, 3=alto; senza "
"arg=mantieni)"

