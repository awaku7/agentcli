#: src/uagent\util_tools.py:1167
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Eseguire questa skill come istruzione a livello di sistema e mantenerla attiva in questa sessione?\n"
"\n"
"Nome: %(name)s\n"
"Percorso: %(path)s\n"
"\n"
"Procedere? Inserisci y per eseguire, oppure c per annullare."

#: src/uagent\util_tools.py:1229
#, python-format
msgid ""
"[clean] Invalid argument: %(arg)r (specify number=threshold; default is "
"%(default)d)"
msgstr ""
"[clean] Argomento non valido: %(arg)r (specifica numero=soglia; predefinito "
"%(default)d)"

#: src/uagent\util_tools.py:1278
#, python-format
msgid ""
"will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"eliminerà i file di log della conversazione (scheck_log_*.jsonl) dal disco.\n"
"Directory log: %(dir)s\n"
"Regola: numero totale di messaggi user/assistant/tool esclusi i system <= %(threshold)d\n"
"Destinazioni: %(n)d\n"
"\n"
"Procedere? Premi y per eseguire, oppure c per annullare."

#: src/uagent\util_tools.py:1346
#, python-format
msgid " - (%(count)d msgs) %(path)s"
msgstr " - (%(count)d messaggi) %(path)s"

#: src/uagent\util_tools.py:1390
#, python-format
msgid ""
"will overwrite the current session log file and prepend the loaded log (no backup).\n"
"\n"
"Current log: %(cur_log)s\n"
"Source log: %(src_log)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"sovrascriverà il file di log della sessione corrente e anteporrà il log caricato (nessun backup).\n"
"\n"
"Log corrente: %(cur_log)s\n"
"Log sorgente: %(src_log)s\n"
"\n"
"Procedere? Premi y per eseguire, oppure c per annullare."

#: src/uagent\util_tools.py:1521
#, python-brace-format
