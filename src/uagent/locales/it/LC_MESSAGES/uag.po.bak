#: src/uagent/util_tools.py:212
msgid ""
"Non-interactive mode. Do not start the stdin loop; exit after processing the"
" startup file (if any)."
msgstr ""
"Modalità non interattiva. Non avviare il ciclo stdin; uscire dopo aver "
"elaborato il file di avvio (se presente)."

#: src/uagent/util_tools.py:661
msgid ""
"[Skill execution]\n"
"This skill is intended to be run. Read the skill body carefully and follow the instructions.\n"
"If the skill contains tasks, continue until they are complete.\n"
"Use tools as needed.\n"
msgstr ""
"[Esecuzione skill]\n"
"Questa skill è destinata a essere eseguita. Leggi attentamente il corpo della skill e segui le istruzioni.\n"
"Se la skill contiene attività, continua finché non sono completate.\n"
"Usa gli strumenti secondo necessità.\n"

#: src/uagent/util_tools.py:668
msgid "When finished, always call `finish_skill` if available.\n"
msgstr "Quando hai finito, chiama sempre `finish_skill` se disponibile.\n"

#: src/uagent/util_tools.py:806
msgid ""
"Select a skill number to run. Enter c to cancel.\n"
"Tip: :skills clear  (remove applied skills)\n"
"Enter number:"
msgstr ""
"Seleziona un numero di skill da eseguire. Inserisci c per annullare.\n"
"Suggerimento: :skills clear  (rimuovi le skill applicate)\n"
"Inserisci il numero:"

#: src/uagent/util_tools.py:842
#, python-format
msgid ""
"Run this skill as a system-level instruction and keep it active in this session?\n"
"\n"
"Name: %(name)s\n"
"Path: %(path)s\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
"Run this skill as a system-level instruction and keep it active in this "
"session?\\n\\nName: %(name)s\\nPath: %(path)s\\n\\nProceed? Enter y to run, "
"or c to cancel."

#: src/uagent/util_tools.py:950
#, python-format
msgid ""
":clean will delete conversation log files (scheck_log_*.jsonl) from disk.\n"
"Log dir: %(dir)s\n"
"Rule: total user/assistant/tool messages excluding system <= %(threshold)d\n"
"Targets: %(n)d\n"
"\n"
"Proceed? Enter y to run, or c to cancel."
msgstr ""
":clean will delete conversation log files (scheck_log_*.jsonl) from "
"disk.\\nLog dir: %(dir)s\\nRule: total user/assistant/tool messages "
"excluding system <= %(threshold)d\\nTargets: %(n)d\\n\\nProceed? Enter y to "
"run, or c to cancel."

#: src/uagent/util_tools.py:1194
#, python-brace-format
msgid ""
"Delete {count} path(s)?\n"
"\n"
"{paths}\n"
"\n"
"Enter y to proceed, or c to cancel."
msgstr ""
"Eliminare {count} percorso/i?\n"
"\n"
"{paths}\n"
"\n"
"Inserisci y per procedere, oppure c per annullare."

#: src/uagent/util_tools.py:1334
#, python-format
msgid "[shrink error] Failed to parse as int: %(arg)r -> keep last %(keep)d"
msgstr ""
"[errore shrink] Impossibile interpretare come intero: %(arg)r -> mantieni "
"gli ultimi %(keep)d"

#: src/uagent/util_tools.py:1361
#, python-format
msgid ""
"[shrink_llm error] Failed to parse as int: %(arg)r -> keep last %(keep)d"
msgstr "[shrink error] Failed to parse as int: %(arg)r -> keep last %(keep)d"

#: src/uagent/util_tools.py:1422 src/uagent/util_tools.py:1455
msgid ""
"Shared long-term memory is not enabled (UAGENT_SHARED_MEMORY_FILE is not "
"set)."
msgstr ""
"Shared long-term memory is not enabled (UAGENT_SHARED_MEMORY_FILE is not "
"set)."

#: src/uagent/util_tools.py:1803
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr ""
"The bullet points listed below are excerpts from this user's long-term "
"memory (persistent memos). Use them as background information about the "
"user. However, always prioritize newly provided information in the "
"conversation, and if it contradicts older information, adopt the latest "
"information.\\n\\n"

#: src/uagent/web.py:457
msgid ""
"Another task is already running in this room. Please retry after it "
"completes."
msgstr ""
"Another task is already running in this room. Please retry after it "
"completes."

#: src/uagent/web.py:536 src/uagent/web.py:655
msgid ""
"Environment variable UAGENT_PROVIDER is not set.\n"
"Please check environment variables when starting the web server."
msgstr "Environment variable UAGENT_PROVIDER is not set."

