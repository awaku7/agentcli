msgstr "Risposta multilinea ricevuta."

#: src/uagent/cli.py:796
msgid ""
"Image file paths were found in your input.\n"
"Do you want to send these images to the LLM (external API) for analysis?\n"
"\n"
msgstr ""
"Nell’input sono stati trovati percorsi di file immagine.\n"
"Vuoi inviare queste immagini all’LLM (API esterna) per l’analisi?\n"
"\n"

#: src/uagent/cli.py:802
msgid "Reply with y to send, or n (or c/cancel) to skip sending."
msgstr ""
"Rispondi con y per inviare, oppure n (o c/cancel) per saltare l’invio."

#: src/uagent/cli.py:817
#, python-format
msgid ""
"Image send confirmation failed; will not send images: %(etype)s: %(err)s"
msgstr ""
"Conferma di invio immagini non riuscita; le immagini non verranno inviate: "
