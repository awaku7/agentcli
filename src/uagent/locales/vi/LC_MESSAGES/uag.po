msgstr "Phân đoạn hội thoại:\n"

#: src/uagent/core.py:1528
msgid "Write a concise summary of this chunk."
msgstr "Viết một tóm tắt ngắn gọn về phân đoạn này."

#: src/uagent/core.py:1532
msgid "- You are updating an existing conversation summary.\n"
msgstr "- Bạn đang cập nhật một tóm tắt hội thoại hiện có.\n"

#: src/uagent/core.py:1533
msgid "- Preserve important facts from the previous summary.\n"
msgstr "- Giữ lại các sự thật quan trọng từ tóm tắt trước đó.\n"

#: src/uagent/core.py:1535
msgid ""
"- Merge in the new chunk without losing constraints, decisions, or pending "
