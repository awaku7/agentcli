msgstr ""
"[INFO] shrink_llm: {old_n} -> {new_n} tin nhắn (đã nén {old_part_n} tin nhắn"
" cũ hơn thành 1 tóm tắt; giữ lại {tail_n} tin nhắn cuối)"

#: src/uagent/core.py:1608
msgid ""
"[WARN] history compression hit context length even at chunk_size=1; falling "
