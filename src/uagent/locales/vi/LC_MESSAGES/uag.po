msgstr ""
"- Trộn phân đoạn mới vào mà không làm mất các ràng buộc, quyết định hoặc các"
" mục đang chờ xử lý.\n"

#: src/uagent/core.py:1537
msgid "- Keep the result concise and suitable for a system message."
msgstr "- Giữ kết quả ngắn gọn và phù hợp làm tin nhắn hệ thống."

#: src/uagent/core.py:1540
msgid "Previous summary:\n"
msgstr "Tóm tắt trước đó:\n"

#: src/uagent/core.py:1542
msgid "New chunk:\n"
msgstr "Phân đoạn mới:\n"

#: src/uagent/core.py:1544
msgid "Update the summary while keeping the prior context intact."
msgstr "Cập nhật tóm tắt trong khi vẫn giữ nguyên bối cảnh trước đó."

#: src/uagent/core.py:1555
