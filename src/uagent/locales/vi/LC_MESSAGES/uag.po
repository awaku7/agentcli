msgstr ""
"[WARN] Nén lịch sử đã chạm giới hạn ngữ cảnh ngay cả khi chunk_size=1; quay "
"về shrink_messages()."

#: src/uagent/core.py:1618
msgid ""
"[WARN] history compression could not reduce chunk_size further; falling back"
" to shrink_messages()."
msgstr ""
"[WARN] Không thể giảm chunk_size thêm nữa khi nén lịch sử; quay về "
"shrink_messages()."

#: src/uagent/core.py:1626
#, python-format
msgid ""
"[WARN] history compression context length exceeded; retrying with "
