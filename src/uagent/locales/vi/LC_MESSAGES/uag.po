#: C:\KAIHATSU\agentcli\src\uagent\util_tools.py:1673
msgid ""
"The bullet points listed below are excerpts from this user's long-term memory (persistent memos). Use them as background information about the user. However, always prioritize newly provided information in the conversation, and if it contradicts older information, adopt the latest information.\n"
"\n"
msgstr "Các gạch đầu dòng bên dưới là trích đoạn từ bộ nhớ dài hạn của người dùng (ghi chú bền vững). Hãy dùng chúng làm thông tin nền về người dùng. Tuy nhiên, luôn ưu tiên thông tin mới được cung cấp trong cuộc trò chuyện; nếu chúng mâu thuẫn với thông tin cũ, hãy dùng thông tin mới nhất.\n\n"

